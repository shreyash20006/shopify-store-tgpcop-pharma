{% doc %}
  @prompt
    make a page for Why Choose TGPCOP PHARMA?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-choose-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-why-choose-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.spacing_between_elements }}px;
  }

  .ai-why-choose-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-weight: 700;
  }

  .ai-why-choose-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-why-choose-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.spacing_between_elements }}px;
  }

  .ai-why-choose-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: 2px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.card_alignment }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-why-choose-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-why-choose-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-why-choose-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    fill: {{ block.settings.icon_color }};
  }

  .ai-why-choose-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-why-choose-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-why-choose-cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: {{ block.settings.spacing_between_elements }}px;
  }

  .ai-why-choose-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-why-choose-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-why-choose-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-why-choose-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .ai-why-choose-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<why-choose-section-{{ ai_gen_id }} class="ai-why-choose-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-why-choose-header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-why-choose-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <div class="ai-why-choose-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    {% endif %}
  </div>

  <div class="ai-why-choose-grid-{{ ai_gen_id }}">
    {% if block.settings.feature_1_title != blank %}
      <div class="ai-why-choose-card-{{ ai_gen_id }}">
        <div class="ai-why-choose-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5zm0 18c-3.86-.93-7-5.43-7-10V8.3l7-3.11 7 3.11V10c0 4.57-3.14 9.07-7 10z"/>
            <path d="M10.5 14.5l-2.5-2.5-1.41 1.41L10.5 17.5 17 11l-1.41-1.41z"/>
          </svg>
        </div>
        <h3 class="ai-why-choose-card-title-{{ ai_gen_id }}">{{ block.settings.feature_1_title }}</h3>
        <p class="ai-why-choose-card-text-{{ ai_gen_id }}">{{ block.settings.feature_1_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_2_title != blank %}
      <div class="ai-why-choose-card-{{ ai_gen_id }}">
        <div class="ai-why-choose-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
            <path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
          </svg>
        </div>
        <h3 class="ai-why-choose-card-title-{{ ai_gen_id }}">{{ block.settings.feature_2_title }}</h3>
        <p class="ai-why-choose-card-text-{{ ai_gen_id }}">{{ block.settings.feature_2_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_3_title != blank %}
      <div class="ai-why-choose-card-{{ ai_gen_id }}">
        <div class="ai-why-choose-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/>
            <path d="M7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z"/>
          </svg>
        </div>
        <h3 class="ai-why-choose-card-title-{{ ai_gen_id }}">{{ block.settings.feature_3_title }}</h3>
        <p class="ai-why-choose-card-text-{{ ai_gen_id }}">{{ block.settings.feature_3_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_4_title != blank %}
      <div class="ai-why-choose-card-{{ ai_gen_id }}">
        <div class="ai-why-choose-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <h3 class="ai-why-choose-card-title-{{ ai_gen_id }}">{{ block.settings.feature_4_title }}</h3>
        <p class="ai-why-choose-card-text-{{ ai_gen_id }}">{{ block.settings.feature_4_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_5_title != blank %}
      <div class="ai-why-choose-card-{{ ai_gen_id }}">
        <div class="ai-why-choose-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
            <path d="M13 7h-2v5.41l4.29 4.29 1.41-1.41-3.7-3.7z"/>
          </svg>
        </div>
        <h3 class="ai-why-choose-card-title-{{ ai_gen_id }}">{{ block.settings.feature_5_title }}</h3>
        <p class="ai-why-choose-card-text-{{ ai_gen_id }}">{{ block.settings.feature_5_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_6_title != blank %}
      <div class="ai-why-choose-card-{{ ai_gen_id }}">
        <div class="ai-why-choose-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
          </svg>
        </div>
