{% comment %}
  TGPCOP Pharma - boAt-Style Product Card
{% endcomment %}

<article class="boat-product-card">
  <a href="{{ product.url }}" class="boat-card-link">
    
    <div class="boat-card-image-wrap">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '400x500', crop: 'center' }}" alt="{{ product.title }}" loading="lazy" class="boat-card-img">
      {% else %}
        <div class="boat-card-placeholder">📚</div>
      {% endif %}
      
      {% if product.compare_at_price > product.price %}
        <div class="boat-card-badge-sale">SAVE {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</div>
      {% endif %}
    </div>

    <div class="boat-card-info">
      <div class="boat-card-meta">
        <span class="boat-card-tag">Semester Material</span>
        <div class="boat-card-stars">★★★★★ <span class="boat-card-rating-num">4.8</span></div>
      </div>
      
      <h3 class="boat-card-title">{{ product.title }}</h3>
      
      <div class="boat-card-price-row">
        <span class="boat-card-price-now">₹{{ product.price | money_without_currency }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="boat-card-price-was">₹{{ product.compare_at_price | money_without_currency }}</span>
        {% endif %}
      </div>

      <div class="boat-card-footer">
        <form method="post" action="{{ routes.cart_add_url }}">
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          <button type="submit" class="boat-card-btn">
            Add to Study Cart
          </button>
        </form>
      </div>
    </div>
  </a>
</article>

<style>
  .boat-product-card { 
    background: #fff; border-radius: 20px; overflow: hidden; 
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    border: 1px solid #f1f5f9;
    height: 100%;
  }
  .boat-product-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); border-color: #22c55e; }

  .boat-card-link { text-decoration: none; color: inherit; display: block; height: 100%; }

  .boat-card-image-wrap { position: relative; padding-top: 100%; background: #f8fafc; overflow: hidden; }
  .boat-card-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: 0.5s ease; }
  .boat-product-card:hover .boat-card-img { transform: scale(1.08); }
  
  .boat-card-badge-sale { position: absolute; top: 12px; left: 12px; background: #ef4444; color: white; padding: 4px 10px; border-radius: 50px; font-weight: 800; font-size: 0.7rem; z-index: 2; }
  
  .boat-card-info { padding: 18px; display: flex; flex-direction: column; gap: 8px; }
  
  .boat-card-meta { display: flex; justify-content: space-between; align-items: center; }
  .boat-card-tag { font-size: 0.65rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
  .boat-card-stars { color: #f59e0b; font-size: 0.8rem; font-weight: 800; }
  .boat-card-rating-num { color: #94a3b8; font-size: 0.75rem; margin-left: 2px; }

  .boat-card-title { font-size: 1.05rem; font-weight: 800; color: #0f172a; margin: 0; line-height: 1.3; height: 2.6em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  
  .boat-card-price-row { display: flex; align-items: baseline; gap: 8px; margin: 4px 0; }
  .boat-card-price-now { font-size: 1.2rem; font-weight: 900; color: #0f172a; }
  .boat-card-price-was { font-size: 0.9rem; color: #94a3b8; text-decoration: line-through; font-weight: 500; }

  .boat-card-btn { 
    width: 100%; background: #22c55e; color: white; border: none; padding: 12px; border-radius: 50px; 
    font-size: 0.85rem; font-weight: 800; cursor: pointer; transition: 0.3s;
    box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);
  }
  .boat-card-btn:hover { background: #16a34a; transform: scale(1.02); box-shadow: 0 8px 20px rgba(34, 197, 94, 0.3); }
</style>
