{% doc %}
  @prompt
    Create a complete product page section for a Shopify store selling digital pharmacy notes. It must include: product image gallery, product title, product price, variant selector (if variants exist), quantity selector, Add to Cart button, Buy Now button, and product description. Use Shopify's native {% form 'product', product %} liquid tag for the cart form. Style with dark green and white color scheme, clean card layout, mobile-friendly. This section should work as a full replacement for the main product section so customers can purchase products.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-page-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: 40px 20px;
  }

  .ai-product-page-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .ai-product-gallery-{{ ai_gen_id }} {
    position: sticky;
    top: 20px;
  }

  .ai-product-main-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
    margin-bottom: 16px;
  }

  .ai-product-main-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-thumbnails-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 12px;
  }

  .ai-product-thumbnail-{{ ai_gen_id }} {
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s ease;
    background-color: #f4f4f4;
  }

  .ai-product-thumbnail-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.primary_color }};
  }

  .ai-product-thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-info-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: 40px;
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.primary_color }};
    font-weight: 700;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | times: 0.8 }}px;
    color: {{ block.settings.text_color }};
    text-decoration: line-through;
    opacity: 0.6;
    font-weight: 400;
  }

  .ai-product-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-product-variant-selector-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-variant-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 4px;
  }

  .ai-product-variant-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.card_background }};
    cursor: pointer;
  }

  .ai-product-variant-select-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.primary_color }};
  }

  .ai-product-quantity-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-quantity-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-product-quantity-selector-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    border: 2px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    width: fit-content;
  }

  .ai-product-quantity-button-{{ ai_gen_id }} {
    background-color: transparent;
    border: none;
    padding: 12px 16px;
    cursor: pointer;
    color: {{ block.settings.text_color }};
    font-size: 18px;
    font-weight: 700;
    transition: background-color 0.2s ease;
  }

  .ai-product-quantity-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.input_border_color }};
  }

  .ai-product-quantity-input-{{ ai_gen_id }} {
    border: none;
    text-align: center;
    width: 60px;
    padding: 12px 8px;
    font-size: 16px;
    color: {{ block.settings.text_color }};
    background-color: transparent;
  }

  .ai-product-quantity-input-{{ ai_gen_id }}:focus {
    outline: none;
  }

  .ai-product-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-product-add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.primary_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .ai-product-add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-product-add-to-cart-{{ ai_gen_id }}:disabled {
    background-color: {{ block.settings.input_border_color }};
    cursor: not-allowed;
    opacity: 0.6;
  }

  .ai-product-buy-now-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.card_background }};
    color: {{ block.settings.primary_color }};
    border: 2px solid {{ block.settings.primary_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ai-product-buy-now-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-product-buy-now-{{ ai_gen_id }}:disabled {
    border-color: {{ block.settings.input_border_color }};
    color: {{ block.settings.input_border_color }};
    cursor: not-allowed;
    opacity: 0.6;
  }

  .ai-product-description-{{ ai_gen_id }} {
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-product-description-title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-product-description-content-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-product-description-content-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-product-description-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-product-availability-{{ ai_gen_id }} {
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 20px;
    font-size: 14px;
    font-weight: 600;
  }

  .ai-product-availability-{{ ai_gen_id }}.in-stock {
    background-color: #e8f5e9;
    color: #2e7d32;
  }

  .ai-product-availability-{{ ai_gen_id }}.out-of-stock {
    background-color: #ffebee;
    color: #c62828;
  }

  @media screen and (max-width: 989px) {
    .ai-product-page-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-product-gallery-{{ ai_gen_id }} {
      position: static;
    }

    .ai-product-info-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-product-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-page-{{ ai_gen_id }} {
      padding: 20px 16px;
    }

    .ai-product-thumbnails-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
      gap: 8px;
    }
  }
{% endstyle %}

<product-page-{{ ai_gen_id }} class="ai-product-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-page-container-{{ ai_gen_id }}">
    <div class="ai-product-gallery-{{ ai_gen_id }}">
      <div class="ai-product-main-image-{{ ai_gen_id }}">
        {% if product.featured_media %}
          <img
            id="ai-main-image-{{ ai_gen_id }}"
            src="{{ product.featured_media | image_url: width: 800 }}"
            alt="{{ product.featured_media.alt | escape }}"
            width="800"
            height="800"
            loading="eager"
          >
        {% else %}
          <div style="aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center;">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      {% if product.media.size > 1 %}
        <div class="ai-product-thumbnails-{{ ai_gen_id }}">
          {% for media in product.media limit: 6 %}
            <div
              class="ai-product-thumbnail-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-media-id="{{ media.id }}"
              data-image-url="{{ media | image_url: width: 800 }}"
            >
              <img
                src="{{ media | image_url: width: 100 }}"
                alt="{{ media.alt | escape }}"
                width="100"
                height="100"
                loading="lazy"
              >
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-info-{{ ai_gen_id }}">
      <h1 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h1>

      <div class="ai-product-price-{{ ai_gen_id }}">
        <span id="ai-product-price-value-{{ ai_gen_id }}">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <span class="ai-product-price-compare-{{ ai_gen_id }}" id="ai-product-compare-price-{{ ai_gen_id }}">
            {{ product.selected_or_first_available_variant.compare_at_price | money }}
          </span>
        {% endif %}
      </div>

      {% if product.selected_or_first_available_variant.available %}
        <div class="ai-product-availability-{{ ai_gen_id }} in-stock">
          ✓ Available for instant download
        </div>
      {% else %}
        <div class="ai-product-availability-{{ ai_gen_id }} out-of-stock">
          Currently unavailable
        </div>
      {% endif %}

      {% form 'product', product %}
        <div class="ai-product-form-{{ ai_gen_id }}">
          {% if product.has_only_default_variant == false %}
            <div class="ai-product-variant-selector-{{ ai_gen_id }}">
              {% for option in product.options_with_values %}
                <div>
                  <label class="ai-product-variant-label-{{ ai_gen_id }}" for="ai-option-{{ ai_gen_id }}-{{ forloop.index }}">
                    {{ option.name }}
                  </label>
                  <select
                    id="ai-option-{{ ai_gen_id }}-{{ forloop.index }}"
                    name="options[{{ option.name | escape }}]"
                    class="ai-product-variant-select-{{ ai_gen_id }}"
                    data-option-index="{{ forloop.index0 }}"
                  >
                    {% for value in option.values %}
                      <option
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}selected{% endif %}
                      >
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <input
            type="hidden"
            name="id"
            id="ai-variant-id-{{ ai_gen_id }}"
            value="{{ product.selected_or_first_available_variant.id }}"
          >

          <div class="ai-product-quantity-{{ ai_gen_id }}">
            <label class="ai-product-quantity-label-{{ ai_gen_id }}" for="ai-quantity-{{ ai_gen_id }}">
              Quantity
            </label>
            <div class="ai-product-quantity-selector-{{ ai_gen_id }}">
              <button
                type="button"
                class="ai-product-quantity-button-{{ ai_gen_id }}"
                data-action="decrease"
                aria-label="Decrease quantity"
              >
                −
              </button>
              <input
                type="number"
                id="ai-quantity-{{ ai_gen_id }}"
                name="quantity"
                value="1"
                min="1"
                class="ai-product-quantity-input-{{ ai_gen_id }}"
                aria-label="Quantity"
              >
              <button
                type="button"
                class="ai-product-quantity-button-{{ ai_gen_id }}"
                data-action="increase"
                aria-label="Increase quantity"
              >
                +
              </button>
            </div>
          </div>

          <div class="ai-product-buttons-{{ ai_gen_id }}">
            <button
              type="submit"
              name="add"
              class="ai-product-add-to-cart-{{ ai_gen_id }}"
              {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
            >
              {% if product.selected_or_first_available_variant.available %}
                {{ block.settings.add_to_cart_text }}
              {% else %}
                Sold out
              {% endif %}
            </button>

            {% if block.settings.show_buy_now %}
              <button
                type="button"
                class="ai-product-buy-now-{{ ai_gen_id }}"
                data-buy-now
                {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
              >
                {{ block.settings.buy_now_text }}
              </button>
            {% endif %}
          </div>
        </div>
      {% endform %}

      {% if product.description != blank %}
        <div class="ai-product-description-{{ ai_gen_id }}">
          <h2 class="ai-product-description-title-{{ ai_gen_id }}">
            {{ block.settings.description_heading }}
          </h2>
          <div class="ai-product-description-content-{{ ai_gen_id }}">
            {{ product.description }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</product-page-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productData = {{ product | json }};
        this.currentVariant = {{ product.selected_or_first_available_variant | json }};
      }

      connectedCallback() {
        this.mainImage = this.querySelector('#ai-main-image-{{ ai_gen_id }}');
        this.thumbnails = this.querySelectorAll('.ai-product-thumbnail-{{ ai_gen_id }}');
        this.variantSelects = this.querySelectorAll('.ai-product-variant-select-{{ ai_gen_id }}');
        this.variantIdInput = this.querySelector('#ai-variant-id-{{ ai_gen_id }}');
        this.priceElement = this.querySelector('#ai-product-price-value-{{ ai_gen_id }}');
        this.comparePriceElement = this.querySelector('#ai-product-compare-price-{{ ai_gen_id }}');
        this.addToCartButton = this.querySelector('.ai-product-add-to-cart-{{ ai_gen_id }}');
        this.buyNowButton = this.querySelector('.ai-product-buy-now-{{ ai_gen_id }}');
        this.quantityInput = this.querySelector('#ai-quantity-{{ ai_gen_id }}');
        this.quantityButtons = this.querySelectorAll('.ai-product-quantity-button-{{ ai_gen_id }}');
        this.availabilityElement = this.querySelector('.ai-product-availability-{{ ai_gen_id }}');

        this.setupThumbnails();
        this.setupVariantSelectors();
        this.setupQuantityButtons();
        this.setupBuyNow();
      }

      setupThumbnails() {
        this.thumbnails.forEach((thumbnail) => {
          thumbnail.addEventListener('click', () => {
            const imageUrl = thumbnail.dataset.imageUrl;
            if (this.mainImage && imageUrl) {
              this.mainImage.src = imageUrl;
            }

            this.thumbnails.forEach((t) => t.classList.remove('active'));
            thumbnail.classList.add('active');
          });
        });
      }

      setupVariantSelectors() {
        this.variantSelects.forEach((select) => {
          select.addEventListener('change', () => {
            this.updateVariant();
          });
        });
      }

      setupQuantityButtons() {
        this.quantityButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const action = button.dataset.action;
            const currentValue = parseInt(this.quantityInput.value) || 1;

            if (action === 'increase') {
              this.quantityInput.value = currentValue + 1;
            } else if (action === 'decrease' && currentValue > 1) {
              this.quantityInput.value = currentValue - 1;
            }
          });
        });
      }

      setupBuyNow() {
        if (this.buyNowButton) {
          this.buyNowButton.addEventListener('click', () => {
            const form = this.querySelector('form');
            const formData = new FormData(form);

            fetch('/cart/add.js', {
              method: 'POST',
              body: formData
            })
            .then(response => response.json())
            .then(() => {
              window.location.href = '/checkout';
            })
            .catch((error) => {
              console.error('Error:', error);
            });
          });
        }
      }

      updateVariant() {
        const selectedOptions = [];
        this.variantSelects.forEach((select) => {
          selectedOptions.push(select.value);
        });

        const matchedVariant = this.productData.variants.find((variant) => {
          return variant.options.every((option, index) => {
            return option === selectedOptions[index];
          });
        });

        if (matchedVariant) {
          this.currentVariant = matchedVariant;
          this.updateUI();
        }
      }

      updateUI() {
        if (this.variantIdInput) {
          this.variantIdInput.value = this.currentVariant.id;
        }

        if (this.priceElement) {
          this.priceElement.textContent = this.formatMoney(this.currentVariant.price);
        }

        if (this.comparePriceElement) {
          if (this.currentVariant.compare_at_price > this.currentVariant.price) {
            this.comparePriceElement.textContent = this.formatMoney(this.currentVariant.compare_at_price);
            this.comparePriceElement.style.display = 'inline';
          } else {
            this.comparePriceElement.style.display = 'none';
          }
        }

        if (this.addToCartButton) {
          if (this.currentVariant.available) {
            this.addToCartButton.disabled = false;
            this.addToCartButton.textContent = '{{ block.settings.add_to_cart_text }}';
          } else {
            this.addToCartButton.disabled = true;
            this.addToCartButton.textContent = 'Sold out';
          }
        }

        if (this.buyNowButton) {
          this.buyNowButton.disabled = !this.currentVariant.available;
        }

        if (this.availabilityElement) {
          if (this.currentVariant.available) {
            this.availabilityElement.className = 'ai-product-availability-{{ ai_gen_id }} in-stock';
            this.availabilityElement.textContent = '✓ Available for instant download';
          } else {
            this.availabilityElement.className = 'ai-product-availability-{{ ai_gen_id }} out-of-stock';
            this.availabilityElement.textContent = 'Currently unavailable';
          }
        }

        if (this.currentVariant.featured_media && this.mainImage) {
          const newImageUrl = this.currentVariant.featured_media.preview_image.src;
          this.mainImage.src = newImageUrl;
        }
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return '{{ cart.currency.symbol }}' + amount.toFixed(2);
      }
    }

    customElements.define('product-page-{{ ai_gen_id }}', ProductPage{{ ai_gen_id }});
  })();
</script>

{% schema %}
