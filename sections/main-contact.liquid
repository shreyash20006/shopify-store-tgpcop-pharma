{% comment %}Contact Page - TGPCOP Pharma{% endcomment %}

<section class="contact-page" id="ContactPage">

  <!-- Hero -->
  <div class="cp-hero">
    <div class="container">
      <div class="section-eyebrow">📩 Get In Touch</div>
      <h1 class="cp-title">We're Here To Help You Succeed</h1>
      <p class="cp-subtitle">Have a question about our notes, GPAT prep, or orders? Reach out — we respond within 24 hours.</p>
    </div>
  </div>

  <div class="container cp-body">

    <!-- Contact Cards -->
    <div class="cp-cards-row fade-up">
      <div class="cp-card cp-card-glass">
        <div class="cp-card-icon">📧</div>
        <h3>General Enquiries</h3>
        <a href="mailto:contact@tgpcoppharma.shop">contact@tgpcoppharma.shop</a>
        <a href="mailto:info@tgpcoppharma.shop">info@tgpcoppharma.shop</a>
      </div>
      <div class="cp-card cp-card-glass">
        <div class="cp-card-icon">🛠</div>
        <h3>Support & Orders</h3>
        <a href="mailto:support@tgpcoppharma.shop">support@tgpcoppharma.shop</a>
        <a href="mailto:shreyash@tgpcoppharma.shop">shreyash@tgpcoppharma.shop</a>
      </div>
      <div class="cp-card cp-card-glass cp-card-tg">
        <div class="cp-card-icon">✈️</div>
        <h3>Telegram Community</h3>
        <p>Fastest responses via Telegram. Join 5000+ students for instant support.</p>
        <a href="#" class="cp-tg-btn" target="_blank" rel="noopener">Join Telegram →</a>
      </div>
    </div>

    <!-- Main Grid: Form + FAQ -->
    <div class="cp-main-grid">

      <!-- Contact Form -->
      <div class="cp-form-wrap fade-up">
        <h2 class="cp-section-heading">Send Us a Message</h2>
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="cp-success-msg">🎉 Message received! We'll reply within 24 hours.</div>
          {% endif %}
          {% if form.errors %}
            <div class="cp-error-msg">⚠️ Please fix the errors below and try again.</div>
          {% endif %}
          <div class="cp-form-row">
            <div class="cp-form-group">
              <label for="ContactName">Full Name</label>
              <input type="text" id="ContactName" name="contact[name]" placeholder="e.g. Priya Sharma" required value="{{ form.name }}">
            </div>
            <div class="cp-form-group">
              <label for="ContactEmail">Email Address</label>
              <input type="email" id="ContactEmail" name="contact[email]" placeholder="your@email.com" required value="{{ form.email }}">
            </div>
          </div>
          <div class="cp-form-row">
            <div class="cp-form-group">
              <label for="ContactPhone">Phone / WhatsApp</label>
              <input type="tel" id="ContactPhone" name="contact[phone]" placeholder="+91 XXXXX XXXXX" value="{{ form.phone }}">
            </div>
            <div class="cp-form-group">
              <label for="ContactSubject">Subject</label>
              <select id="ContactSubject" name="contact[subject]">
                <option value="">Select a topic...</option>
                <option value="Order Issue">Order / Payment Issue</option>
                <option value="Content Query">Notes / Content Query</option>
                <option value="GPAT Query">GPAT Preparation</option>
                <option value="Technical Issue">Technical / Download Issue</option>
                <option value="Partnership">Partnership / Collaboration</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>
          <div class="cp-form-group">
            <label for="ContactMessage">Your Message</label>
            <textarea id="ContactMessage" name="contact[body]" rows="5" placeholder="Tell us how we can help you..." required>{{ form.body }}</textarea>
          </div>
          <button type="submit" class="cp-submit-btn" id="ContactSubmitBtn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Send Message
          </button>
        {% endform %}
      </div>

      <!-- FAQ Section -->
      <div class="cp-faq-wrap fade-up">
        <h2 class="cp-section-heading">Frequently Asked Questions</h2>
        <div class="cp-faq-list" id="CPFaqList">

          <div class="cp-faq-item">
            <button class="cp-faq-q" aria-expanded="false">How do I access my notes after purchase?</button>
            <div class="cp-faq-a">
              <p>After successful payment, a download link is sent to your registered email within 5 minutes. You can also access all your purchases from your Shopify account dashboard under "Orders".</p>
            </div>
          </div>

          <div class="cp-faq-item">
            <button class="cp-faq-q" aria-expanded="false">Are the notes updated as per the latest syllabus?</button>
            <div class="cp-faq-a">
              <p>Yes! All our notes are aligned with the latest PCI (Pharmacy Council of India) syllabus. We regularly review and update content to match university exam patterns.</p>
            </div>
          </div>

          <div class="cp-faq-item">
            <button class="cp-faq-q" aria-expanded="false">Which payment methods do you accept?</button>
            <div class="cp-faq-a">
              <p>We accept all major Indian payment methods including UPI (GPay, PhonePe, Paytm), Credit/Debit Cards, Net Banking, and popular Wallets. All payments are 100% secure via Razorpay.</p>
            </div>
          </div>

          <div class="cp-faq-item">
            <button class="cp-faq-q" aria-expanded="false">Do you offer refunds?</button>
            <div class="cp-faq-a">
              <p>Since our products are digital downloads, we generally do not offer refunds once the download link has been accessed. However, if you face a technical issue (e.g., corrupted file), we will replace the file or issue a full refund. Contact us at support@tgpcoppharma.shop.</p>
            </div>
          </div>

          <div class="cp-faq-item">
            <button class="cp-faq-q" aria-expanded="false">Can I share the notes with my friends?</button>
            <div class="cp-faq-a">
              <p>Our notes are for personal use only and are protected under copyright. Sharing or redistributing them without permission is not allowed. However, we offer group/college pricing — contact us for bulk orders!</p>
            </div>
          </div>

          <div class="cp-faq-item">
            <button class="cp-faq-q" aria-expanded="false">Are there free resources available?</button>
            <div class="cp-faq-a">
              <p>Absolutely! We offer 50+ free PDF notes, daily MCQs, and revision sheets. Join our Telegram community for free daily study content and exam alerts delivered to 5000+ students.</p>
            </div>
          </div>

          <div class="cp-faq-item">
            <button class="cp-faq-q" aria-expanded="false">Do you cover nursing and other healthcare subjects?</button>
            <div class="cp-faq-a">
              <p>Yes! We have a dedicated Nursing section covering GNM, B.Sc Nursing, and ANM study materials. More healthcare subjects are being added regularly.</p>
            </div>
          </div>

        </div>

        <!-- Social Links -->
        <div class="cp-social-box">
          <p>Connect with us on social media</p>
          <div class="cp-social-links">
            <a href="#" class="cp-social instagram" aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              Instagram
            </a>
            <a href="#" class="cp-social telegram" aria-label="Telegram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              Telegram
            </a>
            <a href="#" class="cp-social pinterest" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.76 1.22-5.14 1.22-5.14s-.31-.62-.31-1.54c0-1.44.84-2.52 1.88-2.52.89 0 1.32.67 1.32 1.47 0 .89-.57 2.24-.86 3.48-.25 1.04.51 1.88 1.53 1.88 1.83 0 3.06-2.34 3.06-5.11 0-2.12-1.44-3.72-3.82-3.72-2.8 0-4.55 2.09-4.55 4.43 0 .81.24 1.38.61 1.82.17.2.19.28.13.51l-.23.88c-.07.29-.29.39-.54.28-1.52-.62-2.23-2.3-2.23-4.17 0-3.1 2.63-6.87 7.84-6.87 4.22 0 6.99 3.07 6.99 6.37 0 4.38-2.42 7.67-5.98 7.67-1.2 0-2.32-.64-2.7-1.37l-.74 2.85c-.27 1.01-.99 2.29-1.47 3.06A9.98 9.98 0 0 0 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
              Pinterest
            </a>
            <a href="#" class="cp-social whatsapp" aria-label="WhatsApp" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-page { font-family: 'Inter', sans-serif; }

  .cp-hero {
    background: linear-gradient(135deg, #0b1c2c 0%, #132a42 100%);
    padding: 70px 0 50px;
    text-align: center;
    color: white;
  }
  .cp-title { font-size: clamp(1.8rem, 4vw, 2.8rem); color: white; margin-bottom: 12px; }
  .cp-subtitle { color: #94a3b8; font-size: 1.05rem; max-width: 600px; margin: 0 auto; }

  .cp-body { padding: 50px 0 80px; }

  /* Cards Row */
  .cp-cards-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 50px; }

  .cp-card {
    background: white;
    border-radius: 16px;
    padding: 28px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cp-card:hover { transform: translateY(-4px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); border-color: #22c55e; }
  .cp-card-glass { backdrop-filter: blur(10px); }
  .cp-card-tg { background: linear-gradient(135deg, #0088cc 0%, #0066aa 100%); border-color: transparent; color: white; }
  .cp-card-tg h3 { color: white; }
  .cp-card-tg p { color: rgba(255,255,255,0.85); font-size: 0.9rem; margin: 0; }
  .cp-card-icon { font-size: 2rem; margin-bottom: 5px; }
  .cp-card h3 { font-size: 1.05rem; font-weight: 700; color: #0f172a; margin: 0; }
  .cp-card a:not(.cp-tg-btn) { color: #22c55e; font-size: 0.88rem; font-weight: 500; text-decoration: none; }
  .cp-card a:not(.cp-tg-btn):hover { color: #16a34a; text-decoration: underline; }
  .cp-tg-btn {
    display: inline-block; background: white; color: #0088cc;
    padding: 10px 20px; border-radius: 10px; font-weight: 700; font-size: 0.88rem;
    text-decoration: none; margin-top: 10px; transition: all 0.3s;
  }
  .cp-tg-btn:hover { transform: scale(1.05); color: #005f8e; }

  /* Main Grid */
  .cp-main-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .cp-section-heading { font-size: 1.4rem; font-weight: 800; color: #0f172a; margin-bottom: 25px; border-left: 4px solid #22c55e; padding-left: 15px; }

  /* Form */
  .cp-form-wrap { background: white; border-radius: 20px; padding: 35px; border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
  .cp-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px; }
  .cp-form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 15px; }
  .cp-form-group label { font-size: 0.85rem; font-weight: 600; color: #374151; }
  .cp-form-group input,
  .cp-form-group select,
  .cp-form-group textarea {
    padding: 12px 15px; border: 1.5px solid #e2e8f0; border-radius: 10px;
    font-family: 'Inter', sans-serif; font-size: 0.9rem; color: #0f172a;
    background: #f8fafc; outline: none; transition: all 0.25s; width: 100%;
  }
  .cp-form-group input:focus,
  .cp-form-group select:focus,
  .cp-form-group textarea:focus { border-color: #22c55e; background: white; box-shadow: 0 0 0 3px rgba(34,197,94,0.1); }
  .cp-submit-btn {
    width: 100%; background: #22c55e; color: white; border: none;
    padding: 15px; border-radius: 12px; font-size: 1rem; font-weight: 700;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    gap: 10px; transition: all 0.3s; font-family: 'Poppins', sans-serif;
    letter-spacing: 0.5px;
  }
  .cp-submit-btn:hover { background: #16a34a; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(34,197,94,0.3); }
  .cp-success-msg { background: #dcfce7; color: #166534; padding: 12px 16px; border-radius: 10px; margin-bottom: 20px; font-weight: 600; font-size: 0.9rem; }
  .cp-error-msg { background: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 10px; margin-bottom: 20px; font-weight: 600; font-size: 0.9rem; }

  /* FAQ */
  .cp-faq-wrap { display: flex; flex-direction: column; }
  .cp-faq-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 30px; }
  .cp-faq-item { border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
  .cp-faq-q {
    width: 100%; text-align: left; background: white; border: none;
    padding: 16px 20px; font-size: 0.92rem; font-weight: 600; color: #0f172a;
    cursor: pointer; display: flex; justify-content: space-between; align-items: center;
    font-family: 'Inter', sans-serif; transition: background 0.2s;
  }
  .cp-faq-q::after { content: '+'; font-size: 1.3rem; font-weight: 300; color: #22c55e; transition: transform 0.3s; flex-shrink: 0; }
  .cp-faq-q[aria-expanded="true"] { background: #f0fdf4; color: #166534; }
  .cp-faq-q[aria-expanded="true"]::after { content: '−'; }
  .cp-faq-a { display: none; padding: 0 20px 16px; }
  .cp-faq-a.open { display: block; }
  .cp-faq-a p { font-size: 0.88rem; color: #64748b; line-height: 1.7; margin: 0; }

  /* Social */
  .cp-social-box { background: #f8fafc; border-radius: 14px; padding: 20px; }
  .cp-social-box p { font-size: 0.85rem; font-weight: 600; color: #64748b; margin-bottom: 12px; }
  .cp-social-links { display: flex; gap: 10px; flex-wrap: wrap; }
  .cp-social {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 16px; border-radius: 25px; font-size: 0.82rem;
    font-weight: 700; text-decoration: none; transition: all 0.3s; color: white;
  }
  .cp-social.instagram { background: linear-gradient(135deg, #833ab4, #e1306c, #f77737); }
  .cp-social.telegram { background: #0088cc; }
  .cp-social.pinterest { background: #e60023; }
  .cp-social.whatsapp { background: #25d366; }
  .cp-social:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.2); color: white; }

  /* Responsive */
  @media (max-width: 1024px) { .cp-main-grid { grid-template-columns: 1fr; } }
  @media (max-width: 768px) {
    .cp-cards-row { grid-template-columns: 1fr; }
    .cp-form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll('.cp-faq-q').forEach(btn => {
    btn.addEventListener('click', function() {
      const isOpen = this.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.cp-faq-q').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        b.nextElementSibling.classList.remove('open');
      });
      if (!isOpen) {
        this.setAttribute('aria-expanded', 'true');
        this.nextElementSibling.classList.add('open');
      }
    });
  });
</script>

{% schema %}
{
  "name": "Contact Page",
  "settings": [],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
