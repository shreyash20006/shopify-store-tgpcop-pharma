<style>
  .page-404-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    text-align: center;
    padding: 2rem;
    background: var(--color-bg);
  }
  .page-404-container__content {
    background: var(--color-secondary);
    padding: 4rem 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    max-width: 600px;
    width: 100%;
  }
  .page-404-container__title {
    font-size: 6rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 1rem;
    line-height: 1;
    font-family: var(--font-heading);
  }
  .page-404-container__sub {
    font-size: 1.5rem;
    color: var(--color-white);
    margin-bottom: 2rem;
  }
  .page-404-container__text {
    color: #94a3b8;
    margin-bottom: 2rem;
  }
  .page-404-container__search form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .page-404-container__search input[type="search"] {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255,255,255,0.08);
    color: white;
    font-family: var(--font-body);
    outline: none;
  }
  .page-404-container__search input[type="search"]::placeholder { color: #64748b; }
  .page-404-container__search button {
    padding: 0.75rem 1.5rem;
  }
  .page-404-container .btn-outline { border-color: rgba(255,255,255,0.3); color: white; }
  .page-404-container .btn-outline:hover { background: var(--color-primary); border-color: var(--color-primary); color: white; }
</style>

<div class="page-404-container" id="MainContent">
  <div class="page-404-container__content">
    <h1 class="page-404-container__title">404</h1>
    <h2 class="page-404-container__sub">Page Not Found</h2>
    <p class="page-404-container__text">The page you were looking for does not exist. Maybe you want to try searching instead?</p>
    
    <div class="page-404-container__search">
      <form action="{{ routes.search_url }}" method="get" role="search">
        <input type="search" name="q" placeholder="Search for notes, subjects..." value="{{ search.terms | escape }}">
        <button type="submit" class="btn btn-primary">Search</button>
      </form>
    </div>

    <a href="{{ routes.root_url }}" class="btn btn-outline">Back to Homepage</a>
  </div>
</div>

{% schema %}
{
  "name": "404 Page",
  "settings": []
}
{% endschema %}
