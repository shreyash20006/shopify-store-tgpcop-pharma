{% comment %}
  Study Series Section
  Inspired by 90-day infographic study plan layout
{% endcomment %}

<section class="study-series-section" id="StudySeries" aria-label="Study Series">
  <div class="container">

    <!-- Section Header -->
    <div class="section-header text-center">
      <div class="section-eyebrow">📅 Structured Learning</div>
      <h2 class="section-title">
        {{ section.settings.heading | default: '90-Day <span class="text-highlight">Pharmacy Mastery</span> Series' }}
      </h2>
      <p class="section-desc">
        {{ section.settings.description | default: 'Follow our battle-tested study roadmap designed by top pharmacy educators to help you crack GPAT, University Exams and more.' }}
      </p>
    </div>

    <!-- Timeline / Roadmap -->
    <div class="study-roadmap">

      <!-- Phase 1 -->
      <div class="roadmap-phase phase-1">
        <div class="phase-header">
          <div class="phase-badge">Phase 1</div>
          <div class="phase-duration">
            <span class="phase-days">Day 1–30</span>
            <span class="phase-theme">Foundation Building</span>
          </div>
        </div>
        <div class="phase-modules">
          <div class="module-card">
            <div class="module-icon">🔬</div>
            <div class="module-info">
              <h4 class="module-title">Pharmaceutical Chemistry</h4>
              <p class="module-desc">Drug nomenclature, synthesis routes, structure-activity relationships</p>
              <div class="module-topics">
                <span class="topic-tag">Sem 1–2</span>
                <span class="topic-tag">50+ Notes</span>
                <span class="topic-tag">MCQs</span>
              </div>
            </div>
            <div class="module-progress">
              <div class="mp-circle">
                <span class="mp-pct">30</span>
              </div>
            </div>
          </div>
          <div class="module-card">
            <div class="module-icon">🧪</div>
            <div class="module-info">
              <h4 class="module-title">Pharmaceutics Basics</h4>
              <p class="module-desc">Dosage forms, formulation principles, dispensing pharmacy</p>
              <div class="module-topics">
                <span class="topic-tag">Sem 1–3</span>
                <span class="topic-tag">40+ Notes</span>
                <span class="topic-tag">PYQs</span>
              </div>
            </div>
            <div class="module-progress">
              <div class="mp-circle">
                <span class="mp-pct">30</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Connector -->
      <div class="roadmap-connector" aria-hidden="true">
        <div class="connector-line"></div>
        <div class="connector-arrow">▼</div>
      </div>

      <!-- Phase 2 -->
      <div class="roadmap-phase phase-2">
        <div class="phase-header">
          <div class="phase-badge phase-badge-yellow">Phase 2</div>
          <div class="phase-duration">
            <span class="phase-days">Day 31–65</span>
            <span class="phase-theme">Core Subjects Mastery</span>
          </div>
        </div>
        <div class="phase-modules">
          <div class="module-card featured-module">
            <div class="featured-ribbon">🔥 Most Important</div>
            <div class="module-icon">💊</div>
            <div class="module-info">
              <h4 class="module-title">Pharmacology</h4>
              <p class="module-desc">Drug mechanisms, CNS, CVS, Autonomic pharmacology — the heart of GPAT</p>
              <div class="module-topics">
                <span class="topic-tag">Sem 4–6</span>
                <span class="topic-tag">100+ Notes</span>
                <span class="topic-tag">MCQs + PYQs</span>
              </div>
            </div>
            <div class="module-progress">
              <div class="mp-circle mp-circle-yellow">
                <span class="mp-pct">35</span>
              </div>
            </div>
          </div>
          <div class="module-card">
            <div class="module-icon">🌿</div>
            <div class="module-info">
              <h4 class="module-title">Pharmacognosy</h4>
              <p class="module-desc">Crude drugs, secondary metabolites, herbal drug technology</p>
              <div class="module-topics">
                <span class="topic-tag">Sem 3–5</span>
                <span class="topic-tag">60+ Notes</span>
                <span class="topic-tag">Diagrams</span>
              </div>
            </div>
            <div class="module-progress">
              <div class="mp-circle">
                <span class="mp-pct">35</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Connector -->
      <div class="roadmap-connector" aria-hidden="true">
        <div class="connector-line"></div>
        <div class="connector-arrow">▼</div>
      </div>

      <!-- Phase 3 -->
      <div class="roadmap-phase phase-3">
        <div class="phase-header">
          <div class="phase-badge phase-badge-green">Phase 3</div>
          <div class="phase-duration">
            <span class="phase-days">Day 66–90</span>
            <span class="phase-theme">Exam Cracker Mode</span>
          </div>
        </div>
        <div class="phase-modules">
          <div class="module-card">
            <div class="module-icon">🎯</div>
            <div class="module-info">
              <h4 class="module-title">GPAT Previous Year Questions</h4>
              <p class="module-desc">Solved PYQs from 2010–2024, topic-wise analysis & high-yield areas</p>
              <div class="module-topics">
                <span class="topic-tag">2010–2024</span>
                <span class="topic-tag">2000+ MCQs</span>
                <span class="topic-tag">Solved</span>
              </div>
            </div>
            <div class="module-progress">
              <div class="mp-circle mp-circle-green">
                <span class="mp-pct">25</span>
              </div>
            </div>
          </div>
          <div class="module-card">
            <div class="module-icon">⚡</div>
            <div class="module-info">
              <h4 class="module-title">Quick Revision Notes</h4>
              <p class="module-desc">Last-minute revision sheets, memory maps, mnemonics for all subjects</p>
              <div class="module-topics">
                <span class="topic-tag">All Semesters</span>
                <span class="topic-tag">Flashcards</span>
                <span class="topic-tag">Mnemonics</span>
              </div>
            </div>
            <div class="module-progress">
              <div class="mp-circle mp-circle-green">
                <span class="mp-pct">25</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /.study-roadmap -->

    <!-- CTA -->
    <div class="study-series-cta text-center">
      <a href="{{ routes.collections_url }}" class="btn btn-primary btn-lg" id="StudySeriesCTA">
        Start Your 90-Day Journey →
      </a>
      <p class="study-series-note">📌 All materials available as instant digital downloads</p>
    </div>

  </div><!-- /.container -->
</section>

{% schema %}
{
  "name": "Study Series",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "90-Day Pharmacy Mastery Series"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Follow our battle-tested study roadmap designed by top pharmacy educators."
    }
  ],
  "presets": [
    {
      "name": "Study Series"
    }
  ]
}
{% endschema %}
