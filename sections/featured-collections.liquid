{% comment %}
  TGPCOP Pharma - Featured Collections Section
  Educational collection showcase grid
{% endcomment %}

<section class="featured-collections-section" id="FeaturedCollections" aria-label="Featured Collections">
  <div class="container">
    <div class="fc-header text-center fade-up">
      <div class="section-eyebrow">📚 Study Collections</div>
      <h2 class="section-title">Everything You Need To Ace Your Exams</h2>
      <p class="section-desc">Curated collections built specifically for B.Pharm, GPAT aspirants, and nursing students.</p>
    </div>

    <div class="fc-grid fade-up">

      <!-- Semester Notes - Large Card -->
      <a href="{{ section.settings.collection_1_link | default: '/collections/semester-notes' }}" class="fc-card fc-card-large" id="CollectionSemesterNotes">
        <div class="fc-card-bg fc-bg-navy"></div>
        <div class="fc-card-content">
          <div class="fc-card-icon">📚</div>
          <div class="fc-card-tag">Most Popular</div>
          <h3>Semester Notes</h3>
          <p>Complete B.Pharm semester-wise notes from Sem 1 to Sem 8, aligned with PCI syllabus and university exams.</p>
          <div class="fc-card-stats">
            <span>📄 200+ Notes</span>
            <span>🎓 8 Semesters</span>
          </div>
          <div class="fc-card-cta">Browse Notes →</div>
        </div>
      </a>

      <!-- GPAT Preparation -->
      <a href="{{ section.settings.collection_2_link | default: '/collections/gpat-preparation' }}" class="fc-card" id="CollectionGPAT">
        <div class="fc-card-bg fc-bg-green"></div>
        <div class="fc-card-content">
          <div class="fc-card-icon">🎯</div>
          <div class="fc-card-tag fc-tag-yellow">High Demand</div>
          <h3>GPAT Preparation</h3>
          <p>Comprehensive GPAT study pack with subject-wise modules, PYQs and topic analysis.</p>
          <div class="fc-card-stats">
            <span>📋 2000+ MCQs</span>
            <span>📅 PYQ 2010-2024</span>
          </div>
          <div class="fc-card-cta">Start Prep →</div>
        </div>
      </a>

      <!-- MCQ Banks -->
      <a href="{{ section.settings.collection_3_link | default: '/collections/mcq-banks' }}" class="fc-card" id="CollectionMCQs">
        <div class="fc-card-bg fc-bg-purple"></div>
        <div class="fc-card-content">
          <div class="fc-card-icon">✅</div>
          <h3>MCQ Banks</h3>
          <p>Subject-wise MCQ banks with explanations for exams, GPAT and university assessments.</p>
          <div class="fc-card-stats">
            <span>📊 5000+ MCQs</span>
            <span>⚡ With Answers</span>
          </div>
          <div class="fc-card-cta">Practice Now →</div>
        </div>
      </a>

      <!-- PYQs -->
      <a href="{{ section.settings.collection_4_link | default: '/collections/pyqs' }}" class="fc-card" id="CollectionPYQs">
        <div class="fc-card-bg fc-bg-orange"></div>
        <div class="fc-card-content">
          <div class="fc-card-icon">📋</div>
          <h3>Previous Year Papers</h3>
          <p>GPAT, NIPER and university PYQs from 2010–2024 with detailed answer keys.</p>
          <div class="fc-card-stats">
            <span>🗓 15+ Years</span>
            <span>🔑 With Keys</span>
          </div>
          <div class="fc-card-cta">Download PYQs →</div>
        </div>
      </a>

      <!-- Nursing Resources -->
      <a href="{{ section.settings.collection_5_link | default: '/collections/nursing' }}" class="fc-card" id="CollectionNursing">
        <div class="fc-card-bg fc-bg-teal"></div>
        <div class="fc-card-content">
          <div class="fc-card-icon">🏥</div>
          <h3>Nursing Resources</h3>
          <p>GNM, B.Sc Nursing and ANM study materials covering all core nursing subjects.</p>
          <div class="fc-card-stats">
            <span>📖 100+ Notes</span>
            <span>🌡 All Nursing</span>
          </div>
          <div class="fc-card-cta">Explore →</div>
        </div>
      </a>

      <!-- Combo Bundles - Large Card -->
      <a href="{{ section.settings.collection_6_link | default: '/collections/combo-bundles' }}" class="fc-card fc-card-large fc-card-accent" id="CollectionCombos">
        <div class="fc-card-bg fc-bg-gold"></div>
        <div class="fc-card-content">
          <div class="fc-card-icon">🎁</div>
          <div class="fc-card-tag fc-tag-gold">Best Value</div>
          <h3>Combo Bundles</h3>
          <p>Save big with our combo packs! Get complete semester + GPAT + MCQ collections bundled at unbeatable prices.</p>
          <div class="fc-card-stats">
            <span>💰 Save up to 60%</span>
            <span>📦 Complete Packs</span>
          </div>
          <div class="fc-card-cta">View Bundles →</div>
        </div>
      </a>

    </div>

    <!-- Bottom CTA -->
    <div class="fc-bottom-cta fade-up text-center">
      <p>Can't find what you're looking for?</p>
      <a href="{{ routes.collections_url }}" class="btn btn-outline" id="ViewAllCollectionsBtn">View All Collections →</a>
    </div>
  </div>
</section>

<style>
  .featured-collections-section {
    padding: 90px 0;
    background: #f8fafc;
  }

  .fc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 20px;
    margin-top: 50px;
  }

  /* Make large cards span 2 columns */
  .fc-card-large {
    grid-column: span 2;
  }

  .fc-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: white;
    min-height: 220px;
    display: flex;
    align-items: flex-end;
    transition: all 0.4s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .fc-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .fc-card-large {
    min-height: 260px;
  }

  .fc-card-bg {
    position: absolute;
    inset: 0;
    transition: transform 0.4s ease;
  }

  .fc-card:hover .fc-card-bg {
    transform: scale(1.05);
  }

  .fc-bg-navy { background: linear-gradient(135deg, #0b1c2c 0%, #1e3a5f 100%); }
  .fc-bg-green { background: linear-gradient(135deg, #064e3b 0%, #047857 100%); }
  .fc-bg-purple { background: linear-gradient(135deg, #4c1d95 0%, #7c3aed 100%); }
  .fc-bg-orange { background: linear-gradient(135deg, #7c2d12 0%, #c2410c 100%); }
  .fc-bg-teal { background: linear-gradient(135deg, #134e4a 0%, #0f766e 100%); }
  .fc-bg-gold { background: linear-gradient(135deg, #713f12 0%, #d97706 100%); }

  /* Overlay for better text readability */
  .fc-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 60%);
    z-index: 1;
  }

  .fc-card-content {
    position: relative;
    z-index: 2;
    padding: 28px;
    width: 100%;
  }

  .fc-card-icon {
    font-size: 2.5rem;
    margin-bottom: 10px;
    display: block;
  }

  .fc-card-tag {
    display: inline-block;
    background: rgba(34, 197, 94, 0.9);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .fc-tag-yellow {
    background: rgba(234, 179, 8, 0.9);
    color: #1a1a1a;
  }

  .fc-tag-gold {
    background: rgba(245, 158, 11, 0.95);
    color: #1a1a1a;
  }

  .fc-card-content h3 {
    color: white;
    font-size: 1.3rem;
    font-weight: 800;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .fc-card-large .fc-card-content h3 {
    font-size: 1.6rem;
  }

  .fc-card-content p {
    color: rgba(255,255,255,0.85);
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0 0 14px;
  }

  .fc-card-stats {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .fc-card-stats span {
    font-size: 0.78rem;
    font-weight: 600;
    background: rgba(255,255,255,0.15);
    padding: 4px 10px;
    border-radius: 20px;
    backdrop-filter: blur(5px);
  }

  .fc-card-cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 700;
    color: white;
    border-bottom: 2px solid rgba(255,255,255,0.4);
    padding-bottom: 2px;
    transition: all 0.3s;
  }

  .fc-card:hover .fc-card-cta {
    border-color: white;
  }

  /* Bottom CTA */
  .fc-bottom-cta {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }

  .fc-bottom-cta p {
    color: #64748b;
    font-size: 1rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .fc-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .fc-card-large {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .fc-grid {
      grid-template-columns: 1fr;
    }
    .fc-card-large {
      grid-column: span 1;
    }
    .featured-collections-section {
      padding: 60px 0;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "url",
      "id": "collection_1_link",
      "label": "Semester Notes Link"
    },
    {
      "type": "url",
      "id": "collection_2_link",
      "label": "GPAT Preparation Link"
    },
    {
      "type": "url",
      "id": "collection_3_link",
      "label": "MCQ Banks Link"
    },
    {
      "type": "url",
      "id": "collection_4_link",
      "label": "PYQs Link"
    },
    {
      "type": "url",
      "id": "collection_5_link",
      "label": "Nursing Resources Link"
    },
    {
      "type": "url",
      "id": "collection_6_link",
      "label": "Combo Bundles Link"
    }
  ],
  "presets": [
    {
      "name": "Featured Collections"
    }
  ]
}
{% endschema %}
