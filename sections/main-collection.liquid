<style>
  .collection-template {
    padding: 4rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .collection__title {
    font-size: 3rem;
    color: var(--color-text-main);
    text-align: center;
    margin-bottom: 2rem;
  }
  .collection__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>

<div class="collection-template">
  <h1 class="collection__title">{{ collection.title }}</h1>
  
  <div class="collection__grid">
    {%- for product in collection.products -%}
      {% render 'product-card', product: product %}
    {%- else -%}
      <p style="color: var(--color-text-muted); text-align: center; grid-column: 1 / -1;">No products found in this collection.</p>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection Layout",
  "settings": []
}
{% endschema %}
