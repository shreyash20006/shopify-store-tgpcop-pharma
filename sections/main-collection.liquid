{% comment %}
  TGPCOP Pharma - boAt-Style Collection Template
{% endcomment %}

{{ 'theme.css' | asset_url | stylesheet_tag }}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

{%- paginate collection.products by section.settings.products_per_page -%}
<section class="boat-collection-page" id="MainCollection-{{ section.id }}">
  
  <!-- Sleek Collection Header -->
  <header class="boat-collection-hero">
    <div class="container">
      <nav class="boat-breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="sep">/</span>
        <span class="current">{{ collection.title }}</span>
      </nav>

      <div class="boat-hero-content">
        <h1 class="boat-collection-title">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <div class="boat-collection-desc">{{ collection.description }}</div>
        {%- endif -%}
        <div class="boat-collection-badge">{{ collection.products_count }} Premium Materials</div>
      </div>
    </div>
  </header>

  <div class="container boat-collection-layout">
    
    <!-- Modern Toolbar -->
    <div class="boat-collection-toolbar">
      <div class="boat-toolbar-left">
        <div class="boat-filter-pills">
          <a href="{{ collection.url }}" class="boat-pill {% unless current_tags %}active{% endunless %}">All Products</a>
          {%- for tag in collection.all_tags -%}
            {%- if tag contains 'Semester' or tag contains 'GPAT' -%}
              <a href="{{ collection.url }}/{{ tag | handle }}" class="boat-pill {% if current_tags contains tag %}active{% endif %}">{{ tag }}</a>
            {%- endif -%-}
          {%- endfor -%}
        </div>
      </div>

      <div class="boat-toolbar-right">
        <div class="boat-sort-wrap">
          <select name="sort_by" id="SortBy" class="boat-sort-select" onchange="location.href = '{{ collection.url }}?sort_by=' + this.value">
            <option value="manual">Featured</option>
            <option value="best-selling">Best Selling</option>
            <option value="price-ascending">Price: Low to High</option>
            <option value="price-descending">Price: High to Low</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="boat-product-grid" id="ProductGridContainer">
      {%- for product in collection.products -%}
        <div class="boat-grid-item">
          {% render 'product-card', product: product %}
        </div>
      {%- else -%}
        <div class="boat-empty-state">
          <div class="empty-icon">📂</div>
          <h3>No Study Materials Found</h3>
          <p>Try adjusting your filters or search terms.</p>
          <a href="{{ collection.url }}" class="boat-pill active">Reset All</a>
        </div>
      {%- endfor -%}
    </div>

    <!-- Premium Pagination -->
    {%- if paginate.pages > 1 -%}
      <nav class="boat-pagination">
        <ul class="boat-pagination-list">
          {%- if paginate.previous -%}
            <li><a href="{{ paginate.previous.url }}" class="boat-pag-link">Prev</a></li>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            <li>
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="boat-pag-link">{{ part.title }}</a>
              {%- else -%}
                <span class="boat-pag-link {% if part.title == paginate.current_page %}active{% endif %}">{{ part.title }}</span>
              {%- endif -%}
            </li>
          {%- endfor -%}

          {%- if paginate.next -%}
            <li><a href="{{ paginate.next.url }}" class="boat-pag-link">Next</a></li>
          {%- endif -%}
        </ul>
      </nav>
    {%- endif -%}

  </div>
</section>
{%- endpaginate -%}

<style>
  .boat-collection-page { font-family: 'Inter', sans-serif; background: #fdfdfd; padding-bottom: 100px; }
  
  .boat-collection-hero { 
    background: #000b33; color: white; padding: 80px 0; 
    text-align: center; border-radius: 0 0 40px 40px;
    margin-bottom: 40px;
  }
  
  .boat-breadcrumb { font-size: 0.8rem; opacity: 0.6; margin-bottom: 24px; display: flex; justify-content: center; gap: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
  .boat-breadcrumb a { color: white; text-decoration: none; }
  .boat-breadcrumb .current { color: #22c55e; }

  .boat-collection-title { font-size: 3.5rem; font-weight: 900; margin: 0 0 16px; letter-spacing: -1px; }
  .boat-collection-desc { font-size: 1.1rem; opacity: 0.8; max-width: 600px; margin: 0 auto 24px; line-height: 1.6; }
  .boat-collection-badge { background: rgba(34, 197, 94, 0.2); color: #22c55e; display: inline-block; padding: 6px 16px; border-radius: 50px; font-weight: 800; font-size: 0.85rem; border: 1px solid rgba(34, 197, 94, 0.3); }

  .boat-collection-toolbar { 
    display: flex; justify-content: space-between; align-items: center; 
    margin-bottom: 40px; gap: 20px; flex-wrap: wrap;
    background: white; padding: 12px 24px; border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  
  .boat-filter-pills { display: flex; gap: 10px; flex-wrap: wrap; }
  .boat-pill { 
    text-decoration: none; padding: 8px 18px; border-radius: 50px; 
    font-size: 0.85rem; font-weight: 700; color: #1e293b; 
    background: #f1f5f9; transition: 0.3s; border: 1.5px solid transparent;
  }
  .boat-pill:hover, .boat-pill.active { background: #000b33; color: white; }

  .boat-sort-select { 
    border: 1.5px solid #e2e8f0; border-radius: 50px; padding: 8px 20px; 
    font-size: 0.85rem; font-weight: 700; outline: none; cursor: pointer;
    background: white;
  }

  .boat-product-grid { 
    display: grid; grid-template-columns: repeat(1, 1fr); gap: 24px; 
  }
  @media (min-width: 480px) { .boat-product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 992px) { .boat-product-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1200px) { .boat-product-grid { grid-template-columns: repeat(4, 1fr); } }

  .boat-pagination { margin-top: 60px; display: flex; justify-content: center; }
  .boat-pagination-list { display: flex; gap: 8px; list-style: none; padding: 0; }
  .boat-pag-link { 
    min-width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; 
    background: white; border: 1.5px solid #e2e8f0; border-radius: 12px;
    text-decoration: none; color: #1e293b; font-weight: 800; transition: 0.3s;
  }
  .boat-pag-link:hover, .boat-pag-link.active { background: #22c55e; color: white; border-color: #22c55e; box-shadow: 0 4px 15px rgba(34,197,94,0.3); }

  @media (max-width: 768px) {
    .boat-collection-title { font-size: 2.2rem; }
    .boat-collection-hero { padding: 50px 0; border-radius: 0 0 30px 30px; }
  }
</style>

{% schema %}
{
  "name": "boAt-Style Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "label": "Products per page",
      "default": 12
    }
  ]
}
{% endschema %}

