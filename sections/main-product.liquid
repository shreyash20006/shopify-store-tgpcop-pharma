{% comment %}
  TGPCOP Pharma - Ultra-Premium 'boAt-Style' Product Page
  CSS & fonts loaded via layout/theme.liquid
{% endcomment %}

<section class="product-page-boat-style" itemscope itemtype="https://schema.org/Product">
  <div class="container">
    <div class="boat-product-grid">
      
      <!-- Left Column: Image Gallery -->
      <div class="boat-gallery-column">
        <div class="boat-main-image-container">
          {%- if product.featured_image -%}
            <img id="ProductMainImage" src="{{ product.featured_image | img_url: '1000x1200', crop: 'center' }}" alt="{{ product.title }}" class="boat-main-img" loading="eager">
          {%- else -%}
            <div class="boat-placeholder">📚</div>
          {%- endif -%}
          
          {% if product.compare_at_price > product.price %}
            <div class="boat-sale-badge">SAVE {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</div>
          {% endif %}
        </div>

        <div class="boat-thumbnail-gallery">
          {% for image in product.images %}
            <div class="boat-thumb-item {% if forloop.first %}active{% endif %}" onclick="updateProductImage('{{ image | img_url: '1000x1200', crop: 'center' }}', this)">
              <img src="{{ image | img_url: '200x200', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
            </div>
          {% endfor %}
        </div>
      </div>

      <!-- Right Column: Product Details -->
      <div class="boat-info-column">
        <div class="boat-info-header">
          <nav class="boat-breadcrumb">
            <a href="{{ routes.root_url }}">Home</a> / <a href="{{ collection.url | default: '/collections/all' }}">{{ collection.title | default: 'Materials' }}</a>
          </nav>
          
          <h1 class="boat-product-title" itemprop="name">{{ product.title }}</h1>
          
          <div class="boat-rating-row">
            <div class="boat-stars">★★★★★</div>
            <span class="boat-rating-text">4.8/5 (1.2k+ Students)</span>
          </div>

          <div class="boat-price-container">
            <span class="boat-price-current">₹{{ product.price | money_without_currency }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="boat-price-old">₹{{ product.compare_at_price | money_without_currency }}</span>
            {% endif %}
            <span class="boat-tax-info">Inclusive of all taxes</span>
          </div>
        </div>

        <div class="boat-purchase-section">
          {% form 'product', product, id: 'boat-product-form' %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            
            <div class="boat-qty-selector">
              <button type="button" class="boat-qty-btn" onclick="this.nextElementSibling.stepDown()">−</button>
              <input type="number" name="quantity" value="1" min="1" class="boat-qty-input">
              <button type="button" class="boat-qty-btn" onclick="this.previousElementSibling.stepUp()">+</button>
            </div>

            <button type="submit" class="boat-add-to-cart-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              <span>ADD TO STUDY CART</span>
            </button>
          {% endform %}
        </div>

        <!-- Trust Section: 2x2 Grid -->
        <div class="boat-trust-grid">
          <div class="boat-trust-card">
            <div class="btc-icon">⚡</div>
            <div class="btc-info">
              <span class="btc-title">Instant Delivery</span>
              <span class="btc-desc">PDF sent to Email</span>
            </div>
          </div>
          <div class="boat-trust-card">
            <div class="btc-icon">♾️</div>
            <div class="btc-info">
              <span class="btc-title">Lifetime Access</span>
              <span class="btc-desc">Download Anytime</span>
            </div>
          </div>
          <div class="boat-trust-card">
            <div class="btc-icon">🛡️</div>
            <div class="btc-info">
              <span class="btc-title">Secure Payment</span>
              <span class="btc-desc">100% Encrypted</span>
            </div>
          </div>
          <div class="boat-trust-card btc-verified">
            <div class="btc-icon">✅</div>
            <div class="btc-info">
              <span class="btc-title">PCI Verified</span>
              <span class="btc-desc">Trusted by Students</span>
            </div>
          </div>
        </div>

        <div class="boat-product-details">
          <h3 class="boat-details-heading">Product Details</h3>
          <ul class="boat-details-list">
            <li><strong>Subject Focus:</strong> Comprehensive Semester Material</li>
            <li><strong>Format:</strong> High-Resolution Digital PDF</li>
            <li><strong>Key Topics:</strong> Enantiomers, Racemic Mixtures, and Stereoisomerism</li>
            <li><strong>Exam Ready:</strong> Flowcharts, Solved Questions & Diagrams</li>
          </ul>
          
          <div class="boat-rte-content">
            {{ product.description }}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function updateProductImage(src, thumb) {
    document.getElementById('ProductMainImage').src = src;
    document.querySelectorAll('.boat-thumb-item').forEach(item => item.classList.remove('active'));
    thumb.classList.add('active');
  }
</script>

<style>
  .product-page-boat-style { font-family: 'Inter', sans-serif; background: #fff; padding: 40px 0 80px; color: #1a202c; }
  
  .boat-product-grid { display: grid; grid-template-columns: 1fr; gap: 40px; }
  @media (min-width: 992px) { .boat-product-grid { grid-template-columns: 1.1fr 0.9fr; gap: 60px; } }

  /* Gallery Styling */
  .boat-main-image-container { position: relative; border-radius: 24px; overflow: hidden; background: #f8fafc; box-shadow: 0 20px 40px rgba(0,0,0,0.06); border: 1px solid #edf2f7; }
  .boat-main-img { width: 100%; height: auto; display: block; transition: 0.5s ease; }
  .boat-main-img:hover { transform: scale(1.03); }
  .boat-sale-badge { position: absolute; top: 20px; right: 20px; background: #ef4444; color: white; padding: 8px 16px; border-radius: 50px; font-weight: 800; font-size: 0.85rem; z-index: 2; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3); }
  
  .boat-thumbnail-gallery { display: flex; gap: 15px; margin-top: 20px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: none; }
  .boat-thumb-item { width: 80px; height: 80px; border-radius: 12px; cursor: pointer; border: 2px solid transparent; overflow: hidden; flex-shrink: 0; opacity: 0.6; transition: 0.3s; }
  .boat-thumb-item.active { border-color: #22c55e; opacity: 1; transform: translateY(-2px); }
  .boat-thumb-item img { width: 100%; height: 100%; object-fit: cover; }

  /* Info Column Styling */
  .boat-breadcrumb { font-size: 0.9rem; color: #94a3b8; margin-bottom: 15px; font-weight: 500; }
  .boat-breadcrumb a { color: inherit; text-decoration: none; transition: 0.2s; }
  .boat-breadcrumb a:hover { color: #22c55e; }
  
  .boat-product-title { font-size: 2.8rem; font-weight: 800; color: #0f172a; line-height: 1.1; margin-bottom: 15px; letter-spacing: -0.02em; }
  
  .boat-rating-row { display: flex; align-items: center; gap: 12px; margin-bottom: 25px; }
  .boat-stars { color: #f59e0b; font-size: 1.2rem; }
  .boat-rating-text { font-size: 0.95rem; font-weight: 600; color: #64748b; }

  .boat-price-container { display: flex; align-items: baseline; gap: 15px; margin-bottom: 35px; }
  .boat-price-current { font-size: 2.5rem; font-weight: 800; color: #0f172a; }
  .boat-price-old { font-size: 1.4rem; color: #94a3b8; text-decoration: line-through; font-weight: 500; }
  .boat-tax-info { font-size: 0.9rem; color: #64748b; font-weight: 500; }

  .boat-qty-selector { display: inline-flex; align-items: center; background: #f1f5f9; border-radius: 16px; padding: 6px; margin-bottom: 25px; border: 1px solid #e2e8f0; }
  .boat-qty-btn { width: 44px; height: 44px; border: none; background: transparent; cursor: pointer; font-size: 1.4rem; font-weight: 700; color: #475569; border-radius: 12px; transition: 0.2s; }
  .boat-qty-btn:hover { background: #fff; color: #22c55e; }
  .boat-qty-input { width: 55px; border: none; background: transparent; text-align: center; font-weight: 800; font-size: 1.1rem; outline: none; }
  
  .boat-add-to-cart-btn { 
    width: 100%; background: #22C55E; color: white; border: none; padding: 20px; border-radius: 12px; 
    font-size: 1.1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 12px;
    box-shadow: 0 10px 20px rgba(34, 197, 94, 0.2); transition: all 0.3s ease;
    margin-bottom: 30px;
  }
  .boat-add-to-cart-btn:hover { background: #16a34a; transform: translateY(-2px); box-shadow: 0 15px 30px rgba(34, 197, 94, 0.3); }
  .boat-add-to-cart-btn:active { transform: scale(0.95); }

  /* Trust Grid Layout */
  .boat-trust-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 50px; }
  .boat-trust-card { background: #eff6ff; padding: 20px; border-radius: 20px; display: flex; align-items: center; gap: 15px; border: 1px solid #dbeafe; transition: 0.3s; }
  .boat-trust-card:hover { transform: translateY(-2px); border-color: #bfdbfe; }
  .btc-icon { font-size: 1.8rem; flex-shrink: 0; }
  .btc-info { display: flex; flex-direction: column; }
  .btc-title { font-size: 0.95rem; font-weight: 700; color: #1e3a8a; }
  .btc-desc { font-size: 0.8rem; color: #60a5fa; font-weight: 600; margin-top: 2px; }
  
  .btc-verified { background: #f0fdf4; border-color: #bbf7d0; }
  .btc-verified .btc-title { color: #166534; }
  .btc-verified .btc-desc { color: #22c55e; }

  /* Details Styling */
  .boat-details-heading { font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-bottom: 20px; border-left: 4px solid #22c55e; padding-left: 15px; }
  .boat-details-list { padding-left: 0; list-style: none; display: grid; gap: 15px; margin-bottom: 30px; }
  .boat-details-list li { position: relative; padding-left: 30px; font-size: 1rem; color: #4b5563; font-weight: 500; line-height: 1.4; }
  .boat-details-list li::before { content: '✓'; position: absolute; left: 0; color: #22c55e; font-weight: 900; background: #f0fdf4; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; }
  
  .boat-rte-content { font-size: 1.05rem; line-height: 1.8; color: #64748b; }

  @media (max-width: 767px) {
    .boat-product-title { font-size: 2rem; }
    .boat-price-current { font-size: 2rem; }
    .boat-trust-grid { grid-template-columns: 1fr; gap: 12px; }
    .product-page-boat-style { padding: 20px 0 60px; }
  }
</style>

{% schema %}
{
  "name": "boAt-Style Product Page",
  "settings": []
}
{% endschema %}

