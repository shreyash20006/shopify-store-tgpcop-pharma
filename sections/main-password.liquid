{% comment %}
  Main Password / Coming Soon Section
{% endcomment %}

<section class="password-page" id="MainContent">
  <div class="password-page-inner">
    <div class="password-logo">
      <span class="logo-tgpcop">TGPCOP</span><span class="logo-pharma"> PHARMA</span>
    </div>
    <h1 class="password-heading">{{ section.settings.heading | default: "Coming Soon 🚀" }}</h1>
    <p class="password-subheading">{{ section.settings.subheading | default: "India's #1 Pharmacy Education Platform is getting a new look. Enter your email to get notified when we launch!" }}</p>

    {% form 'customer', id: 'PasswordForm' %}
      <div class="password-form-wrap">
        <input type="email" name="contact[email]" placeholder="Enter your email address" class="password-email-input" required autocomplete="email">
        <button type="submit" class="btn btn-primary">Notify Me</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="password-success">🎉 You're on the list! We'll email you when we launch.</p>
      {% endif %}
    {% endform %}

    <div class="password-meta">
      <a href="/password" class="password-admin-link">Store Admin</a>
    </div>
  </div>
</section>

<style>
  .password-page { min-height: 100vh; background: var(--color-secondary); display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
  .password-page-inner { text-align: center; max-width: 560px; width: 100%; }
  .password-logo { font-family: var(--font-heading); font-size: 2rem; font-weight: 900; margin-bottom: 30px; }
  .password-logo .logo-tgpcop { color: white; }
  .password-logo .logo-pharma { color: var(--color-primary); }
  .password-heading { color: white; font-size: 2.5rem; margin-bottom: 15px; }
  .password-subheading { color: #94a3b8; font-size: 1.05rem; margin-bottom: 35px; line-height: 1.6; }
  .password-form-wrap { display: flex; gap: 10px; margin-bottom: 20px; }
  .password-email-input { flex: 1; padding: 14px 18px; border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.08); color: white; font-family: var(--font-body); font-size: 1rem; outline: none; }
  .password-email-input:focus { border-color: var(--color-primary); }
  .password-email-input::placeholder { color: #64748b; }
  .password-success { color: var(--color-primary); font-weight: 600; margin-top: 10px; }
  .password-meta { margin-top: 40px; }
  .password-admin-link { color: #475569; font-size: 0.85rem; }
  .password-admin-link:hover { color: #94a3b8; }
  @media (max-width: 480px) { .password-form-wrap { flex-direction: column; } }
</style>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coming Soon 🚀"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "India's #1 Pharmacy Education Platform is getting a new look. Enter your email to get notified when we launch!"
    }
  ],
  "presets": [
    { "name": "Password Page" }
  ]
}
{% endschema %}
