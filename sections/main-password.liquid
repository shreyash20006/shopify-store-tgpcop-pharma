<div class="password-page">
  <div class="password-card">
    <h1 class="password-title">{{ shop.name }}</h1>
    <p>Our educational platform is launching soon. Please enter the password to access the site.</p>
    
    <div class="password-form">
      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <div class="input-group">
          <input type="password" name="password" id="Password" class="password-input" placeholder="Enter store password" autofocus>
        </div>
        <button type="submit" class="btn btn--primary" style="margin-top: 1rem; width: 100%;">Enter</button>
      {% endform %}
    </div>
    
    <p style="margin-top: 2rem; font-size: 0.8rem; color: var(--color-text-muted);">
      Store Owner? <a href="/admin" style="color: var(--color-highlight);">Log in here</a>
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Password Page",
  "settings": []
}
{% endschema %}
