          </div>
        </div>

        <!-- Study Materials Column -->
        <div class="footer-col">
          <h3 class="footer-col-title">📚 Study Materials</h3>
          <ul class="footer-links">
            <li><a href="{{ routes.collections_url }}/notes" class="footer-link">B.Pharm Notes</a></li>
            <li><a href="{{ routes.collections_url }}/mcqs" class="footer-link">MCQ Banks</a></li>
            <li><a href="{{ routes.collections_url }}/pyqs" class="footer-link">Previous Year Papers</a></li>
            <li><a href="{{ routes.collections_url }}/gpat" class="footer-link">GPAT Preparation</a></li>
            <li><a href="{{ routes.collections_url }}/nursing" class="footer-link">Nursing Resources</a></li>
            <li><a href="{{ routes.collections_url }}/revision" class="footer-link">Quick Revision Notes</a></li>
            <li><a href="/pages/free-pdfs" class="footer-link footer-link-free">🆓 Free PDFs</a></li>
          </ul>
        </div>

        <!-- Subjects Column -->
        <div class="footer-col">
          <h3 class="footer-col-title">🔬 Subjects</h3>
          <ul class="footer-links">
            <li><a href="{{ routes.collections_url }}/pharmacology" class="footer-link">💊 Pharmacology</a></li>
            <li><a href="{{ routes.collections_url }}/pharmaceutics" class="footer-link">🧪 Pharmaceutics</a></li>
            <li><a href="{{ routes.collections_url }}/pharmacognosy" class="footer-link">🌿 Pharmacognosy</a></li>
            <li><a href="{{ routes.collections_url }}/pharmaceutical-chemistry" class="footer-link">⚗️ Pharm. Chemistry</a></li>
            <li><a href="{{ routes.collections_url }}/clinical-pharmacy" class="footer-link">🏥 Clinical Pharmacy</a></li>
            <li><a href="{{ routes.collections_url }}/pharmacokinetics" class="footer-link">📈 Pharmacokinetics</a></li>
            <li><a href="{{ routes.collections_url }}/biotechnology" class="footer-link">🔬 Biotechnology</a></li>
          </ul>
        </div>

        <!-- Info Column -->
        <div class="footer-col">
          <h3 class="footer-col-title">ℹ️ Information</h3>
          <ul class="footer-links">
            <li><a href="/pages/about" class="footer-link">About TGPCOP PHARMA</a></li>
            <li><a href="/pages/contact" class="footer-link">Contact Us</a></li>
            <li><a href="/pages/faq" class="footer-link">FAQs</a></li>
            <li><a href="/pages/refund-policy" class="footer-link">Refund Policy</a></li>
            <li><a href="/pages/privacy-policy" class="footer-link">Privacy Policy</a></li>
            <li><a href="/pages/terms-of-service" class="footer-link">Terms of Service</a></li>
            <li><a href="/blogs/updates" class="footer-link">Blog & Updates</a></li>
          </ul>
        </div>

      </div><!-- /.footer-grid -->
    </div><!-- /.container -->
  </div><!-- /.footer-top -->

  <!-- Footer Newsletter -->
  <div class="footer-newsletter">
    <div class="container">
      <div class="newsletter-inner">
        <div class="newsletter-text">
          <h3>📬 Get Free Study Tips & Updates</h3>
          <p>Join 5000+ students. Get free notes, exam tips, and GPAT updates directly to your inbox.</p>
        </div>
        <form class="newsletter-form" id="FooterNewsletterForm" action="/contact#footer-newsletter-form" method="post" accept-charset="UTF-8">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-input-wrap">
            <input
              type="email"
              name="contact[email]"
              id="newsletter-email"
              class="newsletter-input"
              placeholder="Enter your email address"
              required
              aria-label="Email address for newsletter"
            >
            <button type="submit" class="newsletter-btn" id="NewsletterSubmit">
              Subscribe Free
            </button>
          </div>
          <p class="newsletter-disclaimer">No spam. Unsubscribe anytime. 100% free.</p>
        </form>
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-inner">
        <p class="footer-copyright">
          &copy; {{ 'now' | date: '%Y' }} TGPCOP PHARMA. All rights reserved. Made with ❤️ for Pharmacy Students of India.
        </p>
        <div class="footer-payment">
          <span class="payment-label">We Accept:</span>
          <div class="payment-icons">
            <span class="payment-icon">💳 UPI</span>
            <span class="payment-icon">🏦 Net Banking</span>
            <span class="payment-icon">💰 Cards</span>
            <span class="payment-icon">📱 Wallets</span>
          </div>
        </div>
      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand Tagline",
      "default": "India's #1 Pharmacy Education Platform"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
