              contact@tgpcoppharma.shop
            </a>
            <a href="mailto:support@tgpcoppharma.shop" class="footer-email">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              support@tgpcoppharma.shop
            </a>
            <a href="mailto:info@tgpcoppharma.shop" class="footer-email">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              info@tgpcoppharma.shop
            </a>
          </div>
          <!-- Social Links -->
          <div class="footer-social">
            <a href="https://instagram.com/tgpcoppharma" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">
