{% comment %}
  Premium "boAt-Style" Footer for TGPCOP PHARMA
  Features: Deep navy aesthetic, high-conversion newsletter, and clean grid.
{% endcomment %}

<footer class="site-footer" id="SiteFooter" role="contentinfo">

  <!-- Newsletter Section (Premium Overlay Style) -->
  <div class="footer-newsletter">
    <div class="container">
      <div class="newsletter-card">
        <div class="newsletter-info">
          <h2 class="newsletter-title">{{ section.settings.newsletter_heading }}</h2>
          <p class="newsletter-subtext">{{ section.settings.newsletter_text }}</p>
        </div>
        <div class="newsletter-form-container">
          {% form 'customer', class: 'footer-newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-input-group">
              <input
                type="email"
                name="contact[email]"
                class="newsletter-input"
                placeholder="Enter your email"
                required
              >
              <button type="submit" class="newsletter-submit-btn">
                Subscribe <span class="mobile-hide">Now</span>
              </button>
            </div>
            {% if form.posted_successfully? %}
              <p class="newsletter-success">🎉 Success! Welcome to the family.</p>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>
  </div>

  <!-- Main Footer Content -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        
        <!-- Brand Column -->
        <div class="footer-col brand-col">
          <div class="footer-logo">
            {% if section.settings.footer_logo != blank %}
              <img src="{{ section.settings.footer_logo | img_url: '150x' }}" alt="{{ shop.name }}" loading="lazy">
            {% else %}
              <div class="logo-text">
                <span class="logo-tgpcop">TGPCOP</span>
                <span class="logo-pharma">PHARMA</span>
              </div>
            {% endif %}
          </div>
          <p class="footer-description">{{ section.settings.tagline }}</p>
          
          <div class="footer-social-links">
            {% if section.settings.instagram != blank %}
              <a href="{{ section.settings.instagram }}" class="social-icon" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </a>
            {% endif %}
            {% if section.settings.youtube != blank %}
              <a href="{{ section.settings.youtube }}" class="social-icon" aria-label="YouTube">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"></path><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon></svg>
              </a>
            {% endif %}
            {% if section.settings.telegram != blank %}
              <a href="{{ section.settings.telegram }}" class="social-icon" aria-label="Telegram">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </a>
            {% endif %}
            {% if section.settings.whatsapp != blank %}
              <a href="{{ section.settings.whatsapp }}" class="social-icon" aria-label="WhatsApp">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              </a>
            {% endif %}
          </div>
        </div>

        <!-- Links Column 1 -->
        <div class="footer-col">
          <h3 class="footer-heading">{{ section.settings.menu_1_title }}</h3>
          <ul class="footer-link-list">
            {% for link in linklists[section.settings.menu_1].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
            {% if section.settings.menu_1 == blank %}
               <li><a href="#">B.Pharm Notes</a></li>
               <li><a href="#">MCQ Banks</a></li>
               <li><a href="#">PYQ Papers</a></li>
               <li><a href="#">GPAT Prep</a></li>
            {% endif %}
          </ul>
        </div>

        <!-- Links Column 2 -->
        <div class="footer-col">
          <h3 class="footer-heading">{{ section.settings.menu_2_title }}</h3>
          <ul class="footer-link-list">
            {% for link in linklists[section.settings.menu_2].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
            {% if section.settings.menu_2 == blank %}
               <li><a href="#">Pharmacology</a></li>
               <li><a href="#">Pharmaceutics</a></li>
               <li><a href="#">Pharmacognosy</a></li>
               <li><a href="#">Pharma Chemistry</a></li>
            {% endif %}
          </ul>
        </div>

        <!-- Links Column 3 (Contact/Info) -->
        <div class="footer-col">
          <h3 class="footer-heading">{{ section.settings.menu_3_title }}</h3>
          <ul class="footer-link-list">
            {% for link in linklists[section.settings.menu_3].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
            {% if section.settings.menu_3 == blank %}
               <li><a href="#">About Us</a></li>
               <li><a href="#">Contact Us</a></li>
               <li><a href="#">Refund Policy</a></li>
               <li><a href="#">FAQs</a></li>
            {% endif %}
          </ul>
          <div class="footer-contact-info">
             <a href="mailto:{{ section.settings.email_1 }}" class="contact-item">
               <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
               {{ section.settings.email_1 }}
             </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-inner">
        <div class="copyright">
          &copy; {{ 'now' | date: "%Y" }} TGPCOP PHARMA. {{ section.settings.copyright_text }}
        </div>
        <div class="payment-methods">
          <span class="payment-icon">UPI</span>
          <span class="payment-icon">Cards</span>
          <span class="payment-icon">NetBanking</span>
          <span class="payment-icon">Wallets</span>
        </div>
      </div>
    </div>
  </div>

</footer>

<style>
  :root {
    --footer-bg: #000b33;
    --footer-text: #e0e0e0;
    --footer-heading: #ffffff;
    --accent-green: #22c55e;
    --footer-border: rgba(255, 255, 255, 0.1);
  }

  .site-footer {
    background-color: var(--footer-bg);
    color: var(--footer-text);
    padding-top: 60px;
    font-family: 'Inter', sans-serif;
  }

  /* Newsletter Card */
  .footer-newsletter {
    margin-bottom: 60px;
  }

  .newsletter-card {
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
    backdrop-filter: blur(10px);
    border: 1px solid var(--footer-border);
    border-radius: 20px;
    padding: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .newsletter-title {
    color: #fff;
    font-size: 1.8rem;
    margin: 0 0 10px 0;
    font-weight: 700;
  }

  .newsletter-subtext {
    margin: 0;
    opacity: 0.8;
    font-size: 1rem;
  }

  .newsletter-form-container {
    flex: 1;
    max-width: 500px;
  }

  .newsletter-input-group {
    display: flex;
    background: rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 5px;
    border: 1px solid var(--footer-border);
  }

  .newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    color: white;
    padding: 12px 20px;
    outline: none;
    font-size: 1rem;
  }

  .newsletter-submit-btn {
    background-color: var(--accent-green);
    color: white;
    border: none;
    padding: 12px 25px;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .newsletter-submit-btn:hover {
    background-color: #16a34a;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(34, 197, 94, 0.4);
  }

  /* Footer Grid */
  .footer-main {
    padding-bottom: 60px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
  }

  .footer-heading {
    color: var(--footer-heading);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 25px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-link-list li {
    margin-bottom: 12px;
  }

  .footer-link-list a {
    color: var(--footer-text);
    text-decoration: none;
    transition: all 0.2s ease;
    font-size: 0.95rem;
    opacity: 0.7;
  }

  .footer-link-list a:hover {
    color: var(--accent-green);
    opacity: 1;
    padding-left: 5px;
  }

  .footer-description {
    line-height: 1.6;
    margin-bottom: 25px;
    opacity: 0.8;
  }

  /* Logo */
  .logo-tgpcop { font-weight: 800; color: #fff; font-size: 1.5rem; }
  .logo-pharma { font-weight: 300; color: var(--accent-green); font-size: 1.5rem; }

  /* Social Icons */
  .footer-social-links {
    display: flex;
    gap: 15px;
  }

  .social-icon {
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.05);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
    border: 1px solid var(--footer-border);
  }

  .social-icon:hover {
    background: var(--accent-green);
    transform: translateY(-5px);
    border-color: var(--accent-green);
  }

  .social-icon svg {
    width: 20px;
    height: 20px;
  }

  .footer-contact-info {
    margin-top: 20px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--footer-text);
    text-decoration: none;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid var(--footer-border);
    padding: 30px 0;
    background: rgba(0,0,0,0.2);
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    opacity: 0.6;
  }

  .payment-methods {
    display: flex;
    gap: 15px;
  }

  .payment-icon {
    padding: 4px 10px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 991px) {
    .newsletter-card {
      flex-direction: column;
      text-align: center;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 576px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-social-links {
      justify-content: center;
    }
    .footer-bottom-inner {
      flex-direction: column;
      gap: 20px;
    }
    .mobile-hide { display: none; }
    .footer-heading::after {
      content: '';
      display: block;
      width: 30px;
      height: 2px;
      background: var(--accent-green);
      margin: 10px auto 0;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand Tagline",
      "default": "India's #1 Pharmacy Education Platform. Empowering students with premium study materials since 2020."
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "email_1",
      "label": "Contact Email",
      "default": "support@tgpcoppharma.shop"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "telegram",
      "label": "Telegram URL"
    },
    {
      "type": "url",
      "id": "whatsapp",
      "label": "WhatsApp URL"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Menu 1 Title",
      "default": "Study Materials"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Menu 2 Title",
      "default": "Top Subjects"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2"
    },
    {
      "type": "text",
      "id": "menu_3_title",
      "label": "Menu 3 Title",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu 3"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Join the Pharma Community"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Subtext",
      "default": "Get free notes, GPAT updates, and exam tips directly in your inbox."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Made with ❤️ for Pharmacy Students."
    }
  ]
}
{% endschema %}
