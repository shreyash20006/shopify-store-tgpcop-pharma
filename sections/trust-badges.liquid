{% comment %}
  Trust Badges Section
  Stats row beneath hero
{% endcomment %}

<section class="trust-badges-section" id="TrustBadges" aria-label="Trust statistics">
  <div class="container">
    <div class="trust-badges-grid">

      <div class="trust-badge" data-count="5000">
        <div class="trust-badge-icon">🎓</div>
        <div class="trust-badge-content">
          <span class="trust-badge-number counter" data-target="5000">0</span>
          <span class="trust-badge-suffix">+</span>
          <span class="trust-badge-label">Students Enrolled</span>
        </div>
      </div>

      <div class="trust-divider" aria-hidden="true"></div>

      <div class="trust-badge" data-count="1200">
        <div class="trust-badge-icon">📚</div>
        <div class="trust-badge-content">
          <span class="trust-badge-number counter" data-target="1200">0</span>
          <span class="trust-badge-suffix">+</span>
          <span class="trust-badge-label">Study Notes</span>
        </div>
      </div>

      <div class="trust-divider" aria-hidden="true"></div>

      <div class="trust-badge" data-count="50000">
        <div class="trust-badge-icon">📥</div>
        <div class="trust-badge-content">
          <span class="trust-badge-number counter" data-target="50000">0</span>
          <span class="trust-badge-suffix">+</span>
          <span class="trust-badge-label">PDF Downloads</span>
        </div>
      </div>

      <div class="trust-divider" aria-hidden="true"></div>

      <div class="trust-badge" data-count="98">
        <div class="trust-badge-icon">⭐</div>
        <div class="trust-badge-content">
          <span class="trust-badge-number counter" data-target="98">0</span>
          <span class="trust-badge-suffix">%</span>
          <span class="trust-badge-label">Student Satisfaction</span>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [],
  "presets": [
    {
      "name": "Trust Badges"
    }
  ]
}
{% endschema %}
