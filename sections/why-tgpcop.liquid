{% comment %}
  Why TGPCOP Section
  Infographic feature cards explaining our value proposition
{% endcomment %}

<section class="why-tgpcop-section" id="WhyTGPCOP" aria-label="Why Choose TGPCOP PHARMA">
  <div class="container">

    <!-- Section Header -->
    <div class="section-header text-center">
      <div class="section-eyebrow">✨ Why Students Love Us</div>
      <h2 class="section-title">
        Why Choose <span class="text-highlight">TGPCOP PHARMA</span>?
      </h2>
      <p class="section-desc">
        Built by pharmacy students, for pharmacy students. We understand exactly what you need to succeed.
      </p>
    </div>

    <!-- Feature Cards Grid -->
    <div class="why-grid">

      <div class="why-card" data-aos="fade-up" data-aos-delay="0">
        <div class="why-card-icon">
          <span class="why-icon-emoji">🎓</span>
        </div>
        <h3 class="why-card-title">Expert-Curated Content</h3>
        <p class="why-card-desc">
          All notes created by B.Pharm & M.Pharm toppers, aligned with PCI syllabus and exam patterns.
        </p>
        <div class="why-card-stat">
          <span class="stat-num">50+</span>
          <span class="stat-label">Expert Contributors</span>
        </div>
      </div>

      <div class="why-card" data-aos="fade-up" data-aos-delay="100">
        <div class="why-card-icon">
          <span class="why-icon-emoji">⚡</span>
        </div>
        <h3 class="why-card-title">Instant Digital Access</h3>
        <p class="why-card-desc">
          Download immediately after purchase. No waiting, no shipping. Study anytime on any device.
        </p>
        <div class="why-card-stat">
          <span class="stat-num">&lt;2 min</span>
          <span class="stat-label">Delivery Time</span>
        </div>
      </div>

      <div class="why-card" data-aos="fade-up" data-aos-delay="200">
        <div class="why-card-icon">
          <span class="why-icon-emoji">📊</span>
        </div>
        <h3 class="why-card-title">Infographic-Style Notes</h3>
        <p class="why-card-desc">
          Visual learning with flowcharts, tables, mind maps & illustrated diagrams that stick in memory.
        </p>
        <div class="why-card-stat">
          <span class="stat-num">70%</span>
          <span class="stat-label">Better Retention</span>
        </div>
      </div>

      <div class="why-card" data-aos="fade-up" data-aos-delay="0">
        <div class="why-card-icon">
          <span class="why-icon-emoji">🎯</span>
        </div>
        <h3 class="why-card-title">GPAT-Focused Preparation</h3>
        <p class="why-card-desc">
          Dedicated GPAT modules with PYQs from 2010–2024, topic-wise analysis and high-yield areas marked.
        </p>
        <div class="why-card-stat">
          <span class="stat-num">2000+</span>
          <span class="stat-label">GPAT MCQs</span>
        </div>
      </div>

      <div class="why-card" data-aos="fade-up" data-aos-delay="100">
        <div class="why-card-icon">
          <span class="why-icon-emoji">💰</span>
        </div>
        <h3 class="why-card-title">Affordable Pricing</h3>
        <p class="why-card-desc">
          Premium quality at student-friendly prices. Most notes under ₹299. Free resources always available.
        </p>
        <div class="why-card-stat">
          <span class="stat-num">₹99</span>
          <span class="stat-label">Starting Price</span>
        </div>
      </div>

      <div class="why-card" data-aos="fade-up" data-aos-delay="200">
        <div class="why-card-icon">
          <span class="why-icon-emoji">🔄</span>
        </div>
        <h3 class="why-card-title">Regular Updates</h3>
        <p class="why-card-desc">
          Content updated with latest exam patterns, new research and syllabus changes. Lifetime access included.
        </p>
        <div class="why-card-stat">
          <span class="stat-num">♾️</span>
          <span class="stat-label">Lifetime Updates</span>
        </div>
      </div>

    </div><!-- /.why-grid -->

    <!-- Bottom Banner -->
    <div class="why-bottom-banner">
      <div class="why-banner-left">
        <div class="why-banner-icon">🏆</div>
        <div class="why-banner-text">
          <h3>Trusted by 5000+ Pharmacy Students Across India</h3>
          <p>From AIIMS BHU to JIPMER, students nationwide rely on TGPCOP PHARMA for their studies</p>
        </div>
      </div>
      <a href="{{ routes.collections_url }}" class="btn btn-primary" id="WhyCTABtn">Start Learning Free →</a>
    </div>

  </div><!-- /.container -->
</section>

{% schema %}
{
  "name": "Why TGPCOP",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why Choose TGPCOP PHARMA?"
    }
  ],
  "presets": [
    {
      "name": "Why TGPCOP"
    }
  ]
}
{% endschema %}
