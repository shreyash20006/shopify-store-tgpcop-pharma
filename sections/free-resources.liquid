{% comment %}
  TGPCOP Pharma - Free Resources Section
  Dashboard-style layout with free PDFs, MCQs, PYQs
{% endcomment %}

<section class="free-resources-section" id="FreeResources" aria-label="Free Study Resources">
  <div class="container">
    <div class="fr-header text-center fade-up">
      <div class="section-eyebrow">🎁 Free Resources</div>
      <h2 class="section-title">Start Studying For Free Today</h2>
      <p class="section-desc">Access our free collection of study materials, MCQs, and revision sheets — no payment required.</p>
    </div>

    <!-- Dashboard Grid -->
    <div class="fr-dashboard fade-up">

      <!-- Left: Resource Categories -->
      <div class="fr-categories">
        <div class="fr-cat-card fr-cat-primary fade-up">
          <div class="fr-cat-icon">📄</div>
          <div class="fr-cat-info">
            <h3>Free PDF Notes</h3>
            <p>Handpicked notes for quick revision and exam prep</p>
            <div class="fr-cat-stats">
              <span class="fr-stat">
                <strong>50+</strong> PDFs
              </span>
              <span class="fr-stat">
                <strong>Free</strong>
              </span>
            </div>
          </div>
          <a href="{{ section.settings.free_pdfs_link | default: '#' }}" class="fr-cat-btn">Download ↗</a>
        </div>

        <div class="fr-cat-card fade-up" style="animation-delay:0.1s;">
          <div class="fr-cat-icon">✅</div>
          <div class="fr-cat-info">
            <h3>Daily MCQs</h3>
            <p>Practice 10 new MCQs every day across all pharmacy subjects</p>
            <div class="fr-cat-stats">
              <span class="fr-stat"><strong>500+</strong> MCQs</span>
              <span class="fr-stat"><strong>Daily</strong></span>
            </div>
          </div>
          <a href="{{ section.settings.mcqs_link | default: '#' }}" class="fr-cat-btn">Practice ↗</a>
        </div>

        <div class="fr-cat-card fade-up" style="animation-delay:0.2s;">
          <div class="fr-cat-icon">📋</div>
          <div class="fr-cat-info">
            <h3>Previous Year Papers</h3>
            <p>GPAT, university, and semester PYQs with answer keys</p>
            <div class="fr-cat-stats">
              <span class="fr-stat"><strong>10+</strong> Years</span>
              <span class="fr-stat"><strong>With Keys</strong></span>
            </div>
          </div>
          <a href="{{ section.settings.pyqs_link | default: '#' }}" class="fr-cat-btn">View PYQs ↗</a>
        </div>

        <div class="fr-cat-card fade-up" style="animation-delay:0.3s;">
          <div class="fr-cat-icon">⚡</div>
          <div class="fr-cat-info">
            <h3>Quick Revision Sheets</h3>
            <p>1-page summary sheets for last-minute exam revision</p>
            <div class="fr-cat-stats">
              <span class="fr-stat"><strong>80+</strong> Sheets</span>
              <span class="fr-stat"><strong>Printable</strong></span>
            </div>
          </div>
          <a href="{{ section.settings.revision_link | default: '#' }}" class="fr-cat-btn">Download ↗</a>
        </div>
      </div>

      <!-- Right: Telegram CTA + Study Planner -->
      <div class="fr-right-panel">
        <!-- Telegram CTA -->
        <div class="fr-telegram-card fade-up">
          <div class="fr-tg-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="40" height="40">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </div>
          <h3>Join Our Telegram Community</h3>
          <p>5,000+ pharmacy students. Get daily MCQs, notes, exam alerts and study tips for FREE.</p>
          <div class="fr-tg-stats">
            <div class="fr-tg-stat">
              <strong>5K+</strong>
              <span>Members</span>
            </div>
            <div class="fr-tg-stat">
              <strong>Daily</strong>
              <span>Updates</span>
            </div>
            <div class="fr-tg-stat">
              <strong>Free</strong>
              <span>Forever</span>
            </div>
          </div>
          <a href="{{ section.settings.telegram_link | default: 'https://t.me/tgpcopnotes' }}" class="fr-tg-btn" id="JoinTelegramBtn" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
            Join Telegram Free
          </a>
        </div>

        <!-- Study Planner Widget -->
        <div class="fr-planner-card fade-up">
          <div class="fr-planner-header">
            <span class="fr-planner-title">📅 Study Planner</span>
            <span class="fr-planner-badge">Free</span>
          </div>
          <div class="fr-planner-days">
            <div class="fr-day fr-day-done">Mon<span>✓</span></div>
            <div class="fr-day fr-day-done">Tue<span>✓</span></div>
            <div class="fr-day fr-day-today">Wed<span>→</span></div>
            <div class="fr-day">Thu<span>·</span></div>
            <div class="fr-day">Fri<span>·</span></div>
            <div class="fr-day">Sat<span>·</span></div>
            <div class="fr-day fr-day-rest">Sun<span>☀</span></div>
          </div>
          <div class="fr-planner-subjects">
            <div class="fr-ps-item">
              <span class="fr-ps-dot green"></span>
              <span>Pharmacology – Ch 5</span>
              <span class="fr-ps-status done">Done</span>
            </div>
            <div class="fr-ps-item">
              <span class="fr-ps-dot yellow"></span>
              <span>Pharmaceutics – Unit 3</span>
              <span class="fr-ps-status active">Today</span>
            </div>
            <div class="fr-ps-item">
              <span class="fr-ps-dot"></span>
              <span>Pharmacognosy – Glycosides</span>
              <span class="fr-ps-status">Pending</span>
            </div>
          </div>
          <a href="{{ section.settings.planner_link | default: '#' }}" class="fr-planner-download">Download Study Planner PDF →</a>
        </div>
      </div>
    </div>

    <!-- Free Subject Quick Access -->
    <div class="fr-subject-grid fade-up">
      <h3 class="fr-subject-title">Free Resources by Subject</h3>
      <div class="fr-subjects">
        <a href="#" class="fr-subject-chip">
          <span>💊</span> Pharmacology
          <span class="chip-count">12 Free</span>
        </a>
        <a href="#" class="fr-subject-chip">
          <span>🧪</span> Pharmaceutics
          <span class="chip-count">8 Free</span>
        </a>
        <a href="#" class="fr-subject-chip">
          <span>🔬</span> Pharmacognosy
          <span class="chip-count">10 Free</span>
        </a>
        <a href="#" class="fr-subject-chip">
          <span>⚗️</span> Pharma Chemistry
          <span class="chip-count">9 Free</span>
        </a>
        <a href="#" class="fr-subject-chip">
          <span>🎯</span> GPAT MCQs
          <span class="chip-count">200+ Free</span>
        </a>
        <a href="#" class="fr-subject-chip">
          <span>🏥</span> Nursing
          <span class="chip-count">6 Free</span>
        </a>
        <a href="#" class="fr-subject-chip">
          <span>📊</span> Biochemistry
          <span class="chip-count">7 Free</span>
        </a>
        <a href="#" class="fr-subject-chip">
          <span>🧬</span> Microbiology
          <span class="chip-count">5 Free</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .free-resources-section {
    padding: 90px 0;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  }

  .fr-dashboard {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 30px;
    margin-top: 50px;
  }

  /* Category Cards */
  .fr-categories {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .fr-cat-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .fr-cat-card:hover {
    transform: translateX(5px);
    border-color: #22c55e;
    box-shadow: 0 8px 25px rgba(34,197,94,0.1);
  }

  .fr-cat-primary {
    background: linear-gradient(135deg, #0b1c2c 0%, #132a42 100%);
    border-color: transparent;
    color: white;
  }

  .fr-cat-primary .fr-cat-info h3 { color: white; }
  .fr-cat-primary .fr-cat-info p { color: #94a3b8; }
  .fr-cat-primary .fr-stat { color: #22c55e; }

  .fr-cat-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    background: rgba(34,197,94,0.1);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fr-cat-primary .fr-cat-icon {
    background: rgba(255,255,255,0.1);
  }

  .fr-cat-info {
    flex: 1;
  }

  .fr-cat-info h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 4px;
  }

  .fr-cat-info p {
    font-size: 0.85rem;
    color: #64748b;
    margin: 0 0 10px;
  }

  .fr-cat-stats {
    display: flex;
    gap: 15px;
  }

  .fr-stat {
    font-size: 0.8rem;
    color: #475569;
    font-weight: 600;
  }

  .fr-stat strong {
    color: #0f172a;
  }

  .fr-cat-btn {
    background: #22c55e;
    color: white;
    padding: 10px 18px;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 700;
    white-space: nowrap;
    text-decoration: none;
    transition: all 0.3s;
    flex-shrink: 0;
  }

  .fr-cat-btn:hover {
    background: #16a34a;
    color: white;
    transform: scale(1.05);
  }

  /* Right Panel */
  .fr-right-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Telegram Card */
  .fr-telegram-card {
    background: linear-gradient(135deg, #0088cc 0%, #005f8e 100%);
    border-radius: 20px;
    padding: 30px;
    color: white;
    text-align: center;
  }

  .fr-tg-icon {
    width: 70px;
    height: 70px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 15px;
  }

  .fr-telegram-card h3 {
    color: white;
    font-size: 1.2rem;
    margin-bottom: 10px;
  }

  .fr-telegram-card p {
    color: rgba(255,255,255,0.85);
    font-size: 0.9rem;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .fr-tg-stats {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .fr-tg-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .fr-tg-stat strong {
    font-size: 1.1rem;
    font-weight: 800;
  }

  .fr-tg-stat span {
    font-size: 0.75rem;
    opacity: 0.8;
  }

  .fr-tg-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    color: #0088cc;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s;
    width: 100%;
    justify-content: center;
  }

  .fr-tg-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    color: #0088cc;
  }

  /* Study Planner Widget */
  .fr-planner-card {
    background: white;
    border-radius: 20px;
    padding: 24px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .fr-planner-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .fr-planner-title {
    font-weight: 700;
    font-size: 1rem;
    color: #0f172a;
  }

  .fr-planner-badge {
    background: #dcfce7;
    color: #16a34a;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .fr-planner-days {
    display: flex;
    gap: 6px;
    margin-bottom: 16px;
  }

  .fr-day {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    color: #94a3b8;
    background: #f8fafc;
    border-radius: 8px;
    padding: 8px 4px;
  }

  .fr-day-done {
    background: #dcfce7;
    color: #16a34a;
  }

  .fr-day-today {
    background: #0b1c2c;
    color: white;
  }

  .fr-day-rest {
    background: #fff7ed;
    color: #f59e0b;
  }

  .fr-planner-subjects {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 16px;
  }

  .fr-ps-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: #475569;
  }

  .fr-ps-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #cbd5e1;
    flex-shrink: 0;
  }

  .fr-ps-dot.green { background: #22c55e; }
  .fr-ps-dot.yellow { background: #f59e0b; }

  .fr-ps-item span:nth-child(2) {
    flex: 1;
  }

  .fr-ps-status {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    background: #f1f5f9;
    color: #94a3b8;
    white-space: nowrap;
  }

  .fr-ps-status.done { background: #dcfce7; color: #16a34a; }
  .fr-ps-status.active { background: #fef9c3; color: #b45309; }

  .fr-planner-download {
    display: block;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: #22c55e;
    text-decoration: none;
    border-top: 1px solid #f1f5f9;
    padding-top: 14px;
  }

  .fr-planner-download:hover {
    color: #16a34a;
  }

  /* Subject Grid */
  .fr-subject-grid {
    margin-top: 50px;
  }

  .fr-subject-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 20px;
  }

  .fr-subjects {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .fr-subject-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1px solid #e2e8f0;
    padding: 10px 18px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #334155;
    text-decoration: none;
    transition: all 0.3s;
  }

  .fr-subject-chip:hover {
    border-color: #22c55e;
    background: #f0fdf4;
    color: #16a34a;
    transform: translateY(-2px);
  }

  .chip-count {
    background: #f0fdf4;
    color: #22c55e;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
  }

  .fr-subject-chip:hover .chip-count {
    background: #22c55e;
    color: white;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .fr-dashboard {
      grid-template-columns: 1fr;
    }
    .fr-right-panel {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 640px) {
    .fr-right-panel {
      grid-template-columns: 1fr;
    }
    .fr-cat-card {
      flex-wrap: wrap;
    }
    .free-resources-section {
      padding: 60px 0;
    }
  }
</style>

{% schema %}
{
  "name": "Free Resources",
  "settings": [
    {
      "type": "url",
      "id": "free_pdfs_link",
      "label": "Free PDFs Link"
    },
    {
      "type": "url",
      "id": "mcqs_link",
      "label": "Daily MCQs Link"
    },
    {
      "type": "url",
      "id": "pyqs_link",
      "label": "PYQs Link"
    },
    {
      "type": "url",
      "id": "revision_link",
      "label": "Revision Sheets Link"
    },
    {
      "type": "url",
      "id": "telegram_link",
      "label": "Telegram Community Link"
    },
    {
      "type": "url",
      "id": "planner_link",
      "label": "Study Planner Download Link"
    }
  ],
  "presets": [
    {
      "name": "Free Resources"
    }
  ]
}
{% endschema %}
