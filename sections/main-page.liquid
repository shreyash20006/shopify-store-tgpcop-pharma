<style>
  .page-template {
    padding: 4rem 1rem;
    max-width: 800px;
    margin: 0 auto;
    color: var(--color-text-main);
  }
  .page__title {
    font-size: 3rem;
    color: var(--color-accent);
    margin-bottom: 2rem;
    text-align: center;
  }
  .page__content {
    line-height: 1.8;
    color: var(--color-text-muted);
  }
  .page__content h2, .page__content h3 {
    color: var(--color-text-main);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
</style>

<div class="page-template">
  <h1 class="page__title">{{ page.title }}</h1>
  <div class="page__content rte">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Page Layout",
  "settings": []
}
{% endschema %}
