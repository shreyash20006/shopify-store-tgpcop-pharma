{% comment %}
  Testimonials Section
  Student review cards with avatars and ratings
{% endcomment %}

<section class="testimonials-section" id="Testimonials" aria-label="Student Testimonials">
  <div class="container">

    <!-- Section Header -->
    <div class="section-header text-center">
      <div class="section-eyebrow">💬 Student Stories</div>
      <h2 class="section-title">
        What Our <span class="text-highlight">Students Say</span>
      </h2>
      <p class="section-desc">
        Real reviews from pharmacy students who transformed their exam preparation with TGPCOP PHARMA
      </p>
    </div>

    <!-- Rating Summary Bar -->
    <div class="testimonials-summary">
      <div class="ts-overall">
        <div class="ts-score">4.9</div>
        <div class="ts-stars">★★★★★</div>
        <div class="ts-label">Overall Rating</div>
      </div>
      <div class="ts-bars">
        <div class="ts-bar-row">
          <span class="ts-bar-label">5 ★</span>
          <div class="ts-bar"><div class="ts-bar-fill" style="width: 82%;"></div></div>
          <span class="ts-bar-pct">82%</span>
        </div>
        <div class="ts-bar-row">
          <span class="ts-bar-label">4 ★</span>
          <div class="ts-bar"><div class="ts-bar-fill" style="width: 13%;"></div></div>
          <span class="ts-bar-pct">13%</span>
        </div>
        <div class="ts-bar-row">
          <span class="ts-bar-label">3 ★</span>
          <div class="ts-bar"><div class="ts-bar-fill" style="width: 4%;"></div></div>
          <span class="ts-bar-pct">4%</span>
        </div>
        <div class="ts-bar-row">
          <span class="ts-bar-label">2 ★</span>
          <div class="ts-bar"><div class="ts-bar-fill" style="width: 1%;"></div></div>
          <span class="ts-bar-pct">1%</span>
        </div>
        <div class="ts-bar-row">
          <span class="ts-bar-label">1 ★</span>
          <div class="ts-bar"><div class="ts-bar-fill" style="width: 0%;"></div></div>
          <span class="ts-bar-pct">0%</span>
        </div>
      </div>
      <div class="ts-count-box">
        <span class="ts-count">5,200+</span>
        <span class="ts-count-label">Happy Students</span>
      </div>
    </div>

    <!-- Testimonials Grid -->
    <div class="testimonials-grid" id="TestimonialsGrid">
      {% for block in section.blocks %}
        <div class="testimonial-card {% if forloop.first %}featured-testimonial{% endif %}" {{ block.shopify_attributes }}>
          <div class="testimonial-quote">"</div>
          <div class="testimonial-stars">{{ block.settings.stars }}</div>
          <p class="testimonial-text">{{ block.settings.text }}</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-label="{{ block.settings.author }}">{{ block.settings.author | slice: 0, 2 | upcase }}</div>
            <div class="testimonial-info">
              <strong class="testimonial-name">{{ block.settings.author }}</strong>
              <span class="testimonial-college">{{ block.settings.college }}</span>
              <span class="testimonial-product">{{ block.settings.product }}</span>
            </div>
            {% if block.settings.verified %}
              <div class="testimonial-verified">✓ Verified Purchase</div>
            {% endif %}
          </div>
        </div>
      {% else %}
        <!-- Fallbacks -->
        <div class="testimonial-card featured-testimonial">
          <div class="testimonial-quote">"</div>
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">TGPCOP PHARMA notes are an absolute game-changer! The Pharmacology notes with color-coded diagrams helped me visualize drug mechanisms perfectly. Scored 87% in my Sem 5 exams thanks to these materials. The GPAT PYQs section is incredibly detailed with explanations for every wrong option!</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-label="Priya Sharma">PS</div>
            <div class="testimonial-info">
              <strong class="testimonial-name">Priya Sharma</strong>
              <span class="testimonial-college">AIIMS BHU, B.Pharm Final Year</span>
              <span class="testimonial-product">📚 Pharmacology Complete Notes</span>
            </div>
            <div class="testimonial-verified">✓ Verified Purchase</div>
          </div>
        </div>
      {% endfor %}
    </div><!-- /.testimonials-grid -->

    <!-- Testimonial CTA -->
    <div class="testimonials-cta text-center">
      <a href="{{ section.settings.cta_link | default: routes.collections_url }}" class="btn btn-primary btn-lg" id="TestimonialCTABtn">
        {{ section.settings.cta_text | default: 'Join 5000+ Students Today →' }}
      </a>
    </div>

  </div><!-- /.container -->
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Our Students Say"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Join 5000+ Students Today →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "stars",
          "label": "Rating (Stars)",
          "default": "★★★★★"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial Text",
          "default": "This product changed my studying habits completely!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "John Doe"
        },
        {
          "type": "text",
          "id": "college",
          "label": "College Info",
          "default": "Pharmacy College"
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product Referenced",
          "default": "📚 Pharmacology Complete Notes"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Purchase Badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "author": "Priya Sharma", "text": "TGPCOP PHARMA notes are an absolute game-changer! Scored 87% in Sem 5.", "college": "AIIMS BHU", "product": "📚 Pharmacology Complete Notes" } },
        { "type": "testimonial", "settings": { "author": "Rahul Verma", "text": "Finally found notes that actually explain pharmaceutical chemistry in simple language.", "college": "JSS College", "product": "⚗️ Pharm Chemistry Notes" } },
        { "type": "testimonial", "settings": { "author": "Ananya Mishra", "text": "The 90-day GPAT study plan is brilliant! Improved my mock test score from 55% to 78%.", "college": "NIPER", "product": "🎯 GPAT Complete Pack" } }
      ]
    }
  ]
}
{% endschema %}
